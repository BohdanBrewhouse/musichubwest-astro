---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import EventCard from '../components/EventCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const lang = 'sv';
const events = await getCollection('events', e => e.id.startsWith('sv/'));
const sorted = events.sort((a, b) => a.data.date.localeCompare(b.data.date));
const heroSlides = sorted.slice(0, 4);
const cardEvents = sorted.slice(0, 3);
const articles = await getCollection('articles', a => a.id.startsWith('sv/'));
const latestArticles = articles.sort((a, b) => b.data.date.localeCompare(a.data.date)).slice(0, 3);
---
<Base title="Music Hub West – Start" lang={lang} description="En plattform för musikindustrins tillväxt i Västra Sverige.">
  <fragment slot="hreflang">
    <link rel="alternate" hreflang="sv" href={new URL('/', Astro.site)} />
    <link rel="alternate" hreflang="en" href={new URL('/en/', Astro.site)} />
  </fragment>

  <Nav lang={lang} active="start" />

  <section class="hero">
    <div class="hero__slides">
      {heroSlides.map((ev, i) => (
        <div class={`hero__slide ${i === 0 ? 'active' : ''}`}>
          <div class="hero__slide-bg"><img src={ev.data.image} alt="" /></div>
          <div class="hero__slide-content">
            <span class={`badge badge--${ev.data.category === 'Tune In West' ? 'tiw' : ev.data.category === 'Kulturverkstaden' ? 'kv' : 'hsm'} hero__badge`}>{ev.data.category}</span>
            <h1 class="hero__title" data-text={ev.data.title}>{ev.data.title}</h1>
            <p class="hero__subtitle">{ev.data.date} på {ev.data.location}</p>
            <div class="hero__controls">
              <div class="hero__dots">
                {heroSlides.map((_, j) => <button class={`hero__dot ${j === i ? 'active' : ''}`}></button>)}
              </div>
              <a href={`/evenemang/${ev.id.replace('sv/', '')}`} class="btn btn--primary">Anmäl dig nu</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__inner">
      <div class="section__head">
        <h2 class="section__title">Kommande event</h2>
        <a href="/evenemang" class="section__link">Se alla →</a>
      </div>
      <div class="card-grid">
        {cardEvents.map(ev => (
          <EventCard title={ev.data.title} date={ev.data.date} time={ev.data.time}
            category={ev.data.category} image={ev.data.image}
            slug={ev.id.replace('sv/', '')} lang={lang} />
        ))}
      </div>
    </div>
  </section>

  <div class="divider-wave">
    <svg viewBox="0 0 1440 40" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,20 C120,40 240,0 360,20 C480,40 600,0 720,20 C840,40 960,0 1080,20 C1200,40 1320,0 1440,20" stroke="#ccff00" stroke-width="3" fill="none"/>
    </svg>
  </div>

  <section class="section">
    <div class="section__inner">
      <div class="section__head">
        <h2 class="section__title">Nyheter & artiklar</h2>
        <a href="/artiklar" class="section__link">Se alla →</a>
      </div>
      <div class="card-grid">
        {latestArticles.map(a => (
          <ArticleCard
            title={a.data.title}
            author={a.data.author}
            date={a.data.date}
            category={a.data.category}
            description={a.body?.slice(0, 120).replace(/\s+/g, ' ').trim()}
            slug={a.id.replace('sv/', '')}
            lang={lang}
          />
        ))}
      </div>
    </div>
  </section>

  <div class="home-project">
    <div class="home-project__inner">
      <div class="home-project__header">
        <p class="home-project__kicker">Projekt 2026–2029</p>
        <h2 class="home-project__title">Tune In West</h2>
        <p class="home-project__text">Tune In West är ett tidsbegränsat projekt med syfte att stärka musikindustrins infrastruktur och tillväxt i Västra Götaland. Projektet är organiserat i tre arbetspaket som täcker plattformsbyggande, kunskapsutveckling och direkt företagsstöd.</p>
      </div>
      <div class="home-ap-grid">
        <a href="/tune-in-west/music-hub" class="home-ap-card">
          <span class="home-ap-card__num">AP 1</span>
          <h3 class="home-ap-card__title">Music Hub</h3>
          <p class="home-ap-card__desc">Återkommande branschträffar, seminarier och showcase-evenemang. Varje år arrangeras Music Tech Hub Summit — regionens stora mötesplats för teknik och musik.</p>
          <span class="home-ap-card__link">Läs mer →</span>
        </a>
        <a href="/tune-in-west/musik-och-ai" class="home-ap-card">
          <span class="home-ap-card__num">AP 2</span>
          <h3 class="home-ap-card__title">Musik och AI</h3>
          <p class="home-ap-card__desc">Forskning och kunskapsutveckling kring AI:s roll i musikskapande och upphovsrätt. Akademin och branschorganisationer samverkar för att sprida ny kunskap öppet.</p>
          <span class="home-ap-card__link">Läs mer →</span>
        </a>
        <a href="/tune-in-west/kunskapsbyggande" class="home-ap-card">
          <span class="home-ap-card__num">AP 3</span>
          <h3 class="home-ap-card__title">Kunskapsbyggande</h3>
          <p class="home-ap-card__desc">Konkret stöd för små och medelstora musikföretag — LEAN-metodik, mentorskap, internationell studieresa, thinktank och en gemensam samverkansmodell.</p>
          <span class="home-ap-card__link">Läs mer →</span>
        </a>
      </div>
    </div>
  </div>

  <Footer lang={lang} />
</Base>
