---
export interface Props {
  title: string;
  date: string;
  time: string;
  category: string;
  image: string;
  slug: string;
  lang: 'sv' | 'en';
  past?: boolean;
}
const { title, date, time, category, image, slug, lang, past = false } = Astro.props;
const eventsBase = lang === 'en' ? '/en/events' : '/evenemang';

function formatDate(d: string, l: 'sv' | 'en') {
  if (!/^\d{4}-\d{2}-\d{2}$/.test(d)) return d;
  return new Intl.DateTimeFormat(l === 'sv' ? 'sv-SE' : 'en-US', {
    day: 'numeric', month: 'long', year: 'numeric'
  }).format(new Date(d + 'T12:00:00'));
}
const displayDate = formatDate(date, lang);

const badgeClass: Record<string, string> = {
  'Tune In West':     'badge--tiw',
  'Kulturverkstaden': 'badge--kv',
  'Högskolan för scen och musik': 'badge--hsm',
  'VGR':              'badge--vgr',
};
---
<a href={`${eventsBase}/${slug}`} class={`event-card${past ? ' event-card--past' : ''}`} data-category={category}>
  <div class="event-card__image">
    <img src={image} alt={title} loading="lazy" />
    <span class={`badge ${badgeClass[category] ?? ''} event-card__badge`}>{category}</span>
  </div>
  <div class="event-card__body">
    <p class="event-card__datetime">{displayDate} &nbsp;·&nbsp; {time}</p>
    <h3 class="event-card__title">{title}</h3>
  </div>
</a>
