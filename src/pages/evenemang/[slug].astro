---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import EventCard from '../../components/EventCard.astro';
import ShareBar from '../../components/ShareBar.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const events = await getCollection('events', e => e.id.startsWith('sv/'));
  return events.map(ev => ({
    params: { slug: ev.id.replace('sv/', '') },
    props: { ev },
  }));
}

const { ev } = Astro.props;
const { Content } = await render(ev);
const lang = 'sv';

const related = await getCollection('events', e =>
  e.id.startsWith('sv/') && e.id !== ev.id
);

const enEvents = await getCollection('events', e => e.id.startsWith('en/'));
const enMatch = enEvents.find(e => e.data.translationKey === ev.data.translationKey);
const altUrl = enMatch ? `/en/evenemang/${enMatch.id.replace('en/', '')}` : '/en/evenemang';

const badgeClass: Record<string, string> = {
  'Tune In West': 'badge--tiw',
  'Kulturverkstaden': 'badge--kv',
  'HSM': 'badge--hsm',
  'VGR': 'badge--vgr',
};

// Calendar helpers
function toIcsDate(dateStr: string, timeStr: string) {
  const [start] = timeStr.split('–');
  const [h, m] = start.trim().split(':');
  const d = new Date(`${dateStr} ${h}:${m}`);
  if (isNaN(d.getTime())) return '';
  return d.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
}
function toIcsDateEnd(dateStr: string, timeStr: string) {
  const parts = timeStr.split('–');
  const endTime = parts.length > 1 ? parts[1] : parts[0];
  const [h, m] = endTime.trim().split(':');
  const d = new Date(`${dateStr} ${h}:${m}`);
  if (isNaN(d.getTime())) return toIcsDate(dateStr, timeStr);
  d.setHours(d.getHours() + (parts.length === 1 ? 1 : 0));
  return d.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
}

const dtStart = toIcsDate(ev.data.date, ev.data.time);
const dtEnd = toIcsDateEnd(ev.data.date, ev.data.time);
const eventUrl = new URL(`/evenemang/${ev.id.replace('sv/','')}`, Astro.site).toString();

const googleUrl = dtStart ? `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${encodeURIComponent(ev.data.title)}&dates=${dtStart}/${dtEnd}&location=${encodeURIComponent(ev.data.location)}&details=${encodeURIComponent(eventUrl)}` : null;

const icsContent = dtStart ? [
  'BEGIN:VCALENDAR',
  'VERSION:2.0',
  'BEGIN:VEVENT',
  `DTSTART:${dtStart}`,
  `DTEND:${dtEnd}`,
  `SUMMARY:${ev.data.title}`,
  `LOCATION:${ev.data.location}`,
  `URL:${eventUrl}`,
  'END:VEVENT',
  'END:VCALENDAR'
].join('\r\n') : null;
---
<Base title={`${ev.data.title} – Music Hub West`} lang={lang} ogImage={ev.data.image}>
  <fragment slot="hreflang">
    <link rel="alternate" hreflang="sv" href={new URL(`/evenemang/${ev.id.replace('sv/','')}`, Astro.site)} />
    {enMatch && <link rel="alternate" hreflang="en" href={new URL(altUrl, Astro.site)} />}
  </fragment>
  <fragment slot="jsonld">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Event",
      "name": ev.data.title,
      "startDate": ev.data.date,
      "location": { "@type": "Place", "name": ev.data.location },
      "organizer": { "@type": "Organization", "name": ev.data.organizer ?? "Music Hub West" },
      "inLanguage": "sv",
      "url": new URL(`/evenemang/${ev.id.replace('sv/','')}`, Astro.site).toString(),
    })} />
  </fragment>
  <Nav lang={lang} active="events" altUrl={altUrl} />

  <div class="event-header">
    <div class="event-header__inner">
      <a href="/evenemang" class="event-header__back">← Alla event</a>
      <div class="event-header__badge">
        <span class={`badge ${badgeClass[ev.data.category]}`}>{ev.data.category}</span>
      </div>
      <h1 class="event-header__title">{ev.data.title}</h1>
      <div class="event-header__bottom">
        <div class="event-meta-row">
          <div class="event-meta-item">
            <span class="event-meta-item__label">Datum</span>
            <span class="event-meta-item__value">{ev.data.date}</span>
          </div>
          <div class="event-meta-item">
            <span class="event-meta-item__label">Tid</span>
            <span class="event-meta-item__value">{ev.data.time}</span>
          </div>
          <div class="event-meta-item">
            <span class="event-meta-item__label">Plats</span>
            <span class="event-meta-item__value">{ev.data.location}</span>
          </div>
        </div>
        <div class="event-header__actions">
          {ev.data.registration_open && ev.data.registration_url && (
            <a href={ev.data.registration_url} target="_blank" rel="noopener noreferrer" class="btn btn--primary">Anmäl dig nu</a>
          )}
          {googleUrl && (
            <div class="cal-drop" id="cal-drop-sv">
              <button class="cal-drop__trigger" aria-expanded="false" onclick="const d=this.closest('.cal-drop');const open=d.classList.toggle('open');this.setAttribute('aria-expanded',open)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17 2h-1V0h-2v2H8V0H6v2H5C3.9 2 3 2.9 3 4v18c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 20H5V9h14v13z"/></svg>
                Lägg till i kalender
                <svg class="cal-drop__arrow" width="10" height="10" viewBox="0 0 10 10" fill="currentColor"><path d="M1 3l4 4 4-4"/></svg>
              </button>
              <div class="cal-drop__menu">
                <a href={googleUrl} target="_blank" rel="noopener noreferrer" class="cal-drop__item">
                  <span class="cal-drop__item-label">Google Calendar</span>
                </a>
                <a href={`/evenemang/${ev.id.replace('sv/','')}.ics`} class="cal-drop__item">
                  <span class="cal-drop__item-label">Apple / Outlook</span>
                </a>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>

  <div class="event-layout">
    <div>
      <div class="event-image">
        <img src={ev.data.image} alt={ev.data.title} />
      </div>
      <div class="event-content">
        <Content />
      </div>
    </div>

    <div class="event-sidebar" id="anmal">
      <div class="event-cta-box">
        <p class="event-cta-box__title">Anmäl dig till eventet</p>
        <div class="event-cta-box__detail">
          <span class="event-cta-box__detail-label">Datum</span>
          <span class="event-cta-box__detail-value">{ev.data.date}</span>
        </div>
        <div class="event-cta-box__detail">
          <span class="event-cta-box__detail-label">Tid</span>
          <span class="event-cta-box__detail-value">{ev.data.time}</span>
        </div>
        <div class="event-cta-box__detail">
          <span class="event-cta-box__detail-label">Plats</span>
          <span class="event-cta-box__detail-value">{ev.data.location}</span>
        </div>
        {ev.data.spots_left && (
          <div class="event-cta-box__detail">
            <span class="event-cta-box__detail-label">Platser kvar</span>
            <span class="event-cta-box__detail-value">{ev.data.spots_left} av {ev.data.spots_total}</span>
          </div>
        )}
        {ev.data.cost && (
          <div class="event-cta-box__detail">
            <span class="event-cta-box__detail-label">Kostnad</span>
            <span class="event-cta-box__detail-value">{ev.data.cost}</span>
          </div>
        )}
        {ev.data.registration_open && ev.data.registration_url ? (
          <a href={ev.data.registration_url} target="_blank" rel="noopener noreferrer" class="btn btn--primary">Anmäl dig nu</a>
        ) : (
          <span class="btn btn--primary btn--disabled">Anmälan öppnar snart</span>
        )}
        <p class="event-cta-box__note">Bekräftelse skickas via e-post</p>
      </div>
      {ev.data.organizer && (
        <div class="event-organiser">
          <p class="event-organiser__label">Arrangör</p>
          <p class="event-organiser__name">{ev.data.organizer}</p>
          {ev.data.organizer_email && (
            <p class="event-organiser__contact">{ev.data.organizer_email}</p>
          )}
        </div>
      )}
    </div>
  </div>

  <ShareBar lang={lang} title={ev.data.title} />

  {related.length > 0 && (
    <div class="related-events">
      <div class="related-events__inner">
        <h2 class="related-events__title">Fler event</h2>
        <div class="card-grid">
          {related.slice(0, 3).map(r => (
            <EventCard
              title={r.data.title}
              date={r.data.date}
              time={r.data.time}
              category={r.data.category}
              image={r.data.image}
              slug={r.id.replace('sv/', '')}
              lang={lang}
            />
          ))}
        </div>
      </div>
    </div>
  )}

  <Footer lang={lang} />
</Base>
