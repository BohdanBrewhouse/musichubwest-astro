---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import EventCard from '../components/EventCard.astro';
import { getCollection } from 'astro:content';

const lang = 'sv';
const events = await getCollection('events', e => e.id.startsWith('sv/'));
const sorted = events.sort((a, b) => a.data.date.localeCompare(b.data.date));

const today = new Date().toISOString().split('T')[0];
const upcoming = sorted.filter(ev => ev.data.date >= today);
const past     = sorted.filter(ev => ev.data.date < today).reverse();

const monthsFull = ['Januari','Februari','Mars','April','Maj','Juni','Juli','Augusti','September','Oktober','November','December'];

const upcomingGroups: Record<string, typeof sorted> = {};
for (const ev of upcoming) {
  const [year, month] = ev.data.date.split('-');
  const key = `${year}-${month}`;
  if (!upcomingGroups[key]) upcomingGroups[key] = [];
  upcomingGroups[key].push(ev);
}

const pastGroups: Record<string, typeof sorted> = {};
for (const ev of past) {
  const [year, month] = ev.data.date.split('-');
  const key = `${year}-${month}`;
  if (!pastGroups[key]) pastGroups[key] = [];
  pastGroups[key].push(ev);
}

const badgeClass: Record<string, string> = {
  'Tune In West': 'badge--tiw',
  'Kulturverkstaden': 'badge--kv',
  'Högskolan för scen och musik': 'badge--hsm',
  'VGR': 'badge--vgr',
};

function formatDate(d: string) {
  if (!/^\d{4}-\d{2}-\d{2}$/.test(d)) return d;
  return new Intl.DateTimeFormat('sv-SE', { day: 'numeric', month: 'long', year: 'numeric' })
    .format(new Date(d + 'T12:00:00'));
}
---
<Base title="Event – Music Hub West" lang={lang} description="Kommande event inom musik, teknik och kreativt företagande i Västra Götaland. Seminarier, showcases och branschträffar arrangerade av Music Hub West.">
  <fragment slot="hreflang">
    <link rel="alternate" hreflang="sv" href={new URL('/evenemang', Astro.site)} />
    <link rel="alternate" hreflang="en" href={new URL('/en/events', Astro.site)} />
  </fragment>
  <fragment slot="jsonld">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": Astro.site },
        { "@type": "ListItem", "position": 2, "name": "Event", "item": new URL('/evenemang', Astro.site).toString() }
      ]
    })} />
  </fragment>

  <Nav lang={lang} active="events" />

  <!-- Page header -->
  <div class="ev-header">
    <div class="ev-header__inner">
      <div class="ev-header__row">
        <div class="ev-header__left">
          <p class="ev-header__kicker">Music Hub West</p>
          <h1 class="ev-header__title">Evenemang</h1>
        </div>
        <div class="ev-header__right">
          <span class="ev-header__num" id="ev-count">{upcoming.length}</span>
          <span class="ev-header__num-label" id="ev-count-label">kommande<br>event</span>
        </div>
      </div>

      <div class="ev-header__bottom">

        <!-- Upcoming / Archive tabs -->
        <div class="ev-tabs">
          <button class="ev-tab active" id="tab-upcoming" data-tab="upcoming">Kommande</button>
          <button class="ev-tab" id="tab-archive" data-tab="archive">
            Arkiv
            {past.length > 0 && <span class="ev-tab__count">{past.length}</span>}
          </button>
        </div>

        <!-- Desktop: filter chips -->
        <div class="ev-filter-chips" id="ev-filter-chips">
          <span class="ev-filter-label">FILTRERA</span>
          <button class="ev-chip active" data-filter="all">Alla</button>
          <button class="ev-chip" data-filter="Tune In West">Tune In West</button>
          <button class="ev-chip" data-filter="Kulturverkstaden">Kulturverkstaden</button>
          <button class="ev-chip" data-filter="Högskolan för scen och musik">Högskolan för scen och musik</button>
          <button class="ev-chip" data-filter="VGR">VGR</button>
        </div>

        <!-- Mobile: dropdown -->
        <div class="cat-drop" id="cat-drop">
          <button class="cat-drop__btn" id="cat-drop__btn" aria-haspopup="listbox" aria-expanded="false">
            <span id="cat-drop__label">Alla kategorier</span>
            <svg class="cat-drop__caret" width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <ul class="cat-drop__menu" role="listbox" id="cat-drop__menu" hidden>
            <li class="cat-drop__item active" role="option" data-filter="all" aria-selected="true">Alla</li>
            <li class="cat-drop__item" role="option" data-filter="Tune In West" aria-selected="false">Tune In West</li>
            <li class="cat-drop__item" role="option" data-filter="Kulturverkstaden" aria-selected="false">Kulturverkstaden</li>
            <li class="cat-drop__item" role="option" data-filter="Högskolan för scen och musik" aria-selected="false">Högskolan för scen och musik</li>
            <li class="cat-drop__item" role="option" data-filter="VGR" aria-selected="false">VGR</li>
          </ul>
        </div>

        <!-- View toggle -->
        <div class="view-toggle-wrap">
          <div class="agenda-nudge" id="agenda-nudge">
            <span class="agenda-nudge__text">Prova listvy</span>
            <svg class="agenda-nudge__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <button class="agenda-nudge__close" id="agenda-nudge-close" aria-label="Stäng">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 2l8 8M10 2l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
          </div>
          <div class="view-toggle" role="group" aria-label="Välj vy">
          <button class="view-toggle__btn active" id="btn-grid" aria-pressed="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <rect x="1" y="1" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/>
              <rect x="10" y="1" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/>
              <rect x="1" y="10" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/>
              <rect x="10" y="10" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            <span class="view-toggle__tooltip">Grid view</span>
          </button>
          <button class="view-toggle__btn" id="btn-list" aria-pressed="false">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <line x1="1" y1="4" x2="17" y2="4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="1" y1="9" x2="17" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="1" y1="14" x2="17" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span class="view-toggle__tooltip">Agenda view</span>
          </button>
        </div>
        </div><!-- /view-toggle-wrap -->
      </div>
    </div>
  </div>

  <!-- GRID VIEW -->
  <section class="section ev-view" id="view-grid">
    <div class="section__inner">
      <!-- Upcoming -->
      <div class="card-grid" id="grid-upcoming">
        {upcoming.map(ev => (
          <EventCard
            title={ev.data.title}
            date={ev.data.date}
            time={ev.data.time}
            category={ev.data.category}
            image={ev.data.image}
            slug={ev.id.replace('sv/', '')}
            lang={lang}
          />
        ))}
        {upcoming.length === 0 && (
          <p class="ev-empty">Inga kommande event just nu. Kolla tillbaka snart!</p>
        )}
      </div>
      <!-- Archive -->
      <div class="card-grid" id="grid-archive" style="display:none">
        {past.map(ev => (
          <EventCard
            title={ev.data.title}
            date={ev.data.date}
            time={ev.data.time}
            category={ev.data.category}
            image={ev.data.image}
            slug={ev.id.replace('sv/', '')}
            lang={lang}
            past={true}
          />
        ))}
        {past.length === 0 && (
          <p class="ev-empty">Inga tidigare event ännu.</p>
        )}
      </div>
    </div>
  </section>

  <!-- LIST VIEW -->
  <div class="agenda ev-view" id="view-list" style="display:none">
    <div class="agenda__inner">

      <!-- List: Upcoming -->
      <div id="list-upcoming">
        {Object.entries(upcomingGroups).map(([key, evs]) => {
          const [year, monthIdx] = key.split('-');
          const mIdx = parseInt(monthIdx, 10) - 1;
          return (
            <div class="agenda-month" data-month-key={key}>
              <div class="agenda-month__label">
                <span class="agenda-month__name">{monthsFull[mIdx]}</span>
                <span class="agenda-month__year">{year}</span>
              </div>
              {evs.map((ev) => {
                const slug = ev.id.replace('sv/', '');
                return (
                  <a class="agenda-item" href={`/evenemang/${slug}`} data-category={ev.data.category}>
                    <div class="agenda-item__body">
                      <div class="agenda-item__top">
                        <span class={`badge ${badgeClass[ev.data.category] ?? ''}`}>{ev.data.category}</span>
                        <h2 class="agenda-item__title">{ev.data.title}</h2>
                      </div>
                      <p class="agenda-item__meta">
                        <span>{formatDate(ev.data.date)}</span>
                        {ev.data.location && <><span class="agenda-item__dot">·</span><span>{ev.data.location}</span></>}
                        {ev.data.time && <><span class="agenda-item__dot">·</span><span>{ev.data.time}</span></>}
                      </p>
                    </div>
                    <span class="agenda-item__link">
                      {ev.data.registration_open ? 'Anmäl dig' : 'Läs mer'}
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                  </a>
                );
              })}
            </div>
          );
        })}
        {upcoming.length === 0 && (
          <p class="ev-empty">Inga kommande event just nu. Kolla tillbaka snart!</p>
        )}
      </div>

      <!-- List: Archive -->
      <div id="list-archive" style="display:none">
        {Object.entries(pastGroups).map(([key, evs]) => {
          const [year, monthIdx] = key.split('-');
          const mIdx = parseInt(monthIdx, 10) - 1;
          return (
            <div class="agenda-month" data-month-key={key}>
              <div class="agenda-month__label">
                <span class="agenda-month__name">{monthsFull[mIdx]}</span>
                <span class="agenda-month__year">{year}</span>
              </div>
              {evs.map((ev) => {
                const slug = ev.id.replace('sv/', '');
                return (
                  <a class="agenda-item agenda-item--past" href={`/evenemang/${slug}`} data-category={ev.data.category}>
                    <div class="agenda-item__body">
                      <div class="agenda-item__top">
                        <span class={`badge ${badgeClass[ev.data.category] ?? ''}`}>{ev.data.category}</span>
                        <h2 class="agenda-item__title">{ev.data.title}</h2>
                      </div>
                      <p class="agenda-item__meta">
                        <span>{formatDate(ev.data.date)}</span>
                        {ev.data.location && <><span class="agenda-item__dot">·</span><span>{ev.data.location}</span></>}
                        {ev.data.time && <><span class="agenda-item__dot">·</span><span>{ev.data.time}</span></>}
                      </p>
                    </div>
                    <span class="agenda-item__link">
                      Läs mer
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                  </a>
                );
              })}
            </div>
          );
        })}
        {past.length === 0 && (
          <p class="ev-empty">Inga tidigare event ännu.</p>
        )}
      </div>

      <div id="agenda-empty" hidden>
        <p class="agenda-empty">Inga event matchar det valda filtret.</p>
      </div>
    </div>
  </div>

  <Footer lang={lang} />
</Base>

<script is:inline>
(function () {
  var STORAGE_KEY = 'mhw-events-view';

  var btnGrid = document.getElementById('btn-grid');
  var btnList = document.getElementById('btn-list');
  var viewGrid = document.getElementById('view-grid');
  var viewList = document.getElementById('view-list');

  function setView(v) {
    var isGrid = v !== 'list';
    viewGrid.style.display = isGrid ? '' : 'none';
    viewList.style.display = isGrid ? 'none' : '';
    btnGrid.classList.toggle('active', isGrid);
    btnList.classList.toggle('active', !isGrid);
    btnGrid.setAttribute('aria-pressed', isGrid ? 'true' : 'false');
    btnList.setAttribute('aria-pressed', isGrid ? 'false' : 'true');
    try { localStorage.setItem(STORAGE_KEY, v); } catch(e) {}
  }

  var NUDGE_KEY = 'mhw-nudge-dismissed';

  // Hide nudge if already dismissed or already in list view
  var nudge = document.getElementById('agenda-nudge');
  var nudgeClose = document.getElementById('agenda-nudge-close');

  function dismissNudge() {
    if (!nudge) return;
    nudge.style.display = 'none';
    try { localStorage.setItem(NUDGE_KEY, '1'); } catch(e) {}
  }

  try {
    var saved = localStorage.getItem(STORAGE_KEY);
    if (saved === 'list') {
      setView('list');
      if (nudge) nudge.style.display = 'none';
    } else if (localStorage.getItem(NUDGE_KEY) === '1') {
      if (nudge) nudge.style.display = 'none';
    }
  } catch(e) {}

  // Clicking the nudge body → switch to list + dismiss
  if (nudge) {
    nudge.addEventListener('click', function(e) {
      if (e.target === nudgeClose || nudgeClose.contains(e.target)) return;
      setView('list');
      dismissNudge();
    });
  }
  if (nudgeClose) {
    nudgeClose.addEventListener('click', function(e) {
      e.stopPropagation();
      dismissNudge();
    });
  }

  btnGrid.addEventListener('click', function() { setView('grid'); });
  btnList.addEventListener('click', function() { setView('list'); dismissNudge(); });

  // ── Tab switching (upcoming / archive) ──
  var tabUpcoming  = document.getElementById('tab-upcoming');
  var tabArchive   = document.getElementById('tab-archive');
  var gridUpcoming = document.getElementById('grid-upcoming');
  var gridArchive  = document.getElementById('grid-archive');
  var listUpcoming = document.getElementById('list-upcoming');
  var listArchive  = document.getElementById('list-archive');
  var evCount      = document.getElementById('ev-count');
  var evCountLabel = document.getElementById('ev-count-label');

  var upcomingCount = gridUpcoming ? gridUpcoming.querySelectorAll('[data-category]').length : 0;
  var archiveCount  = gridArchive  ? gridArchive.querySelectorAll('[data-category]').length  : 0;

  function setTab(tab) {
    var isUpcoming = tab !== 'archive';
    // grid
    if (gridUpcoming) gridUpcoming.style.display = isUpcoming ? '' : 'none';
    if (gridArchive)  gridArchive.style.display  = isUpcoming ? 'none' : '';
    // list
    if (listUpcoming) listUpcoming.style.display = isUpcoming ? '' : 'none';
    if (listArchive)  listArchive.style.display  = isUpcoming ? 'none' : '';
    // tab buttons
    if (tabUpcoming) tabUpcoming.classList.toggle('active', isUpcoming);
    if (tabArchive)  tabArchive.classList.toggle('active', !isUpcoming);
    // counter
    if (evCount) evCount.textContent = isUpcoming ? upcomingCount : archiveCount;
    if (evCountLabel) evCountLabel.innerHTML = isUpcoming ? 'kommande<br>event' : 'tidigare<br>event';
    // reset category filter
    document.querySelectorAll('.ev-chip').forEach(function(c) { c.classList.remove('active'); });
    var allChip = document.querySelector('.ev-chip[data-filter="all"]');
    if (allChip) allChip.classList.add('active');
    if (catLabel) catLabel.textContent = 'Alla kategorier';
    if (catMenu) {
      catMenu.querySelectorAll('.cat-drop__item').forEach(function(i) {
        i.classList.remove('active');
        i.setAttribute('aria-selected', 'false');
      });
      var allItem = catMenu.querySelector('.cat-drop__item[data-filter="all"]');
      if (allItem) { allItem.classList.add('active'); allItem.setAttribute('aria-selected', 'true'); }
    }
    applyFilter('all');
    try { localStorage.setItem('mhw-events-tab', tab); } catch(e) {}
  }

  if (tabUpcoming) tabUpcoming.addEventListener('click', function() { setTab('upcoming'); });
  if (tabArchive)  tabArchive.addEventListener('click',  function() { setTab('archive'); });

  // Restore saved tab
  try {
    var savedTab = localStorage.getItem('mhw-events-tab');
    if (savedTab === 'archive') setTab('archive');
  } catch(e) {}

  // ── Desktop chip filter ──
  document.querySelectorAll('.ev-chip').forEach(function(chip) {
    chip.addEventListener('click', function() {
      document.querySelectorAll('.ev-chip').forEach(function(c) { c.classList.remove('active'); });
      chip.classList.add('active');
      applyFilter(chip.getAttribute('data-filter'));
    });
  });

  // ── Category dropdown filter ──
  var catBtn   = document.getElementById('cat-drop__btn');
  var catMenu  = document.getElementById('cat-drop__menu');
  var catLabel = document.getElementById('cat-drop__label');

  function applyFilter(filter) {
    document.querySelectorAll('[data-category]').forEach(function(el) {
      el.style.display = (filter === 'all' || el.dataset.category === filter) ? '' : 'none';
    });
    requestAnimationFrame(function() {
      var anyVisible = false;
      document.querySelectorAll('.agenda-month').forEach(function(group) {
        var items = group.querySelectorAll('.agenda-item');
        var hasVisible = Array.from(items).some(function(el) { return el.style.display !== 'none'; });
        group.style.display = hasVisible ? '' : 'none';
        if (hasVisible) anyVisible = true;
      });
      var empty = document.getElementById('agenda-empty');
      if (empty) empty.hidden = anyVisible;
    });
  }

  if (catBtn && catMenu) {
    catBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      var isOpen = !catMenu.hidden;
      catMenu.hidden = isOpen;
      catBtn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
    });

    catMenu.querySelectorAll('.cat-drop__item').forEach(function(item) {
      item.addEventListener('click', function() {
        var filter = item.getAttribute('data-filter');
        catLabel.textContent = filter === 'all' ? 'Alla kategorier' : item.textContent.trim();
        catMenu.querySelectorAll('.cat-drop__item').forEach(function(i) {
          i.classList.remove('active');
          i.setAttribute('aria-selected', 'false');
        });
        item.classList.add('active');
        item.setAttribute('aria-selected', 'true');
        catMenu.hidden = true;
        catBtn.setAttribute('aria-expanded', 'false');
        applyFilter(filter);
      });
    });

    document.addEventListener('click', function() {
      catMenu.hidden = true;
      catBtn.setAttribute('aria-expanded', 'false');
    });
  }
})();
</script>

<style>
  /* ── Header ── */
  .ev-header {
    background: var(--black);
    padding: 64px 40px 0;
  }
  .ev-header__inner { max-width: var(--max); margin: 0 auto; }
  .ev-header__row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }
  .ev-header__kicker {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lime);
    margin-bottom: 12px;
  }
  .ev-header__title {
    font-size: clamp(52px, 9vw, 120px);
    font-weight: 800;
    letter-spacing: -0.045em;
    line-height: 0.88;
    color: var(--white);
    margin: 0;
  }
  .ev-header__right {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding-bottom: 10px;
    flex-shrink: 0;
  }
  .ev-header__num {
    font-size: clamp(52px, 6vw, 80px);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--lime);
  }
  .ev-header__num-label {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.35);
    line-height: 1.3;
  }

  /* ── Tabs (upcoming / archive) ── */
  .ev-tabs {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }
  .ev-tab {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 16px;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 4px;
    color: rgba(255,255,255,0.5);
    font-family: var(--font);
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
    white-space: nowrap;
  }
  .ev-tab:hover { border-color: rgba(255,255,255,0.35); color: var(--white); }
  .ev-tab.active { background: var(--lime); border-color: var(--lime); color: var(--black); }
  .ev-tab__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    background: rgba(255,255,255,0.15);
    border-radius: 9px;
    font-size: 11px;
    font-weight: 800;
    line-height: 1;
  }
  .ev-tab.active .ev-tab__count { background: rgba(0,0,0,0.2); }

  /* ── Empty state ── */
  .ev-empty {
    grid-column: 1 / -1;
    padding: 64px 0;
    text-align: center;
    color: rgba(255,255,255,0.35);
    font-size: 15px;
  }

  /* ── Past agenda items (dimmed) ── */
  .agenda-item--past { opacity: 0.65; }
  .agenda-item--past:hover { opacity: 1; }

  /* ── Header bottom row (filters + toggle) ── */
  .ev-header__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border-top: 1px solid var(--black-3);
    border-bottom: 1px solid var(--black-3);
    padding: 16px 0;
  }
  /* ── Desktop filter chips ── */
  .ev-filter-chips {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .ev-filter-label {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.4);
    margin-right: 4px;
    white-space: nowrap;
  }
  .ev-chip {
    display: inline-flex;
    align-items: center;
    padding: 7px 14px;
    border: 1px solid rgba(255,255,255,0.2);
    background: transparent;
    border-radius: 4px;
    color: rgba(255,255,255,0.7);
    font-family: var(--font);
