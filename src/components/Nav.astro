      </svg>
      <span class="nav__logo-text">Music<br>Hub West</span>
    </a>
    <ul class="nav__links">
      {links.map(link => (
        <li>
          <a href={link.href} class={active === link.key ? 'active' : ''} aria-current={active === link.key ? 'page' : undefined}>{link.label}</a>
