---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import EventCard from '../../components/EventCard.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const lang = 'en';
const events = await getCollection('events', e => e.id.startsWith('en/'));
const sorted = events.sort((a, b) => a.data.date.localeCompare(b.data.date));
const articles = await getCollection('articles', a => a.id.startsWith('en/'));
const latestArticles = articles.sort((a, b) => b.data.date.localeCompare(a.data.date)).slice(0, 3);
---
<Base title="Music Hub West – Start" lang={lang} description="A platform for the music industry's growth in Western Sweden. Events, articles and projects in music, tech and creative business in Västra Götaland.">
  <fragment slot="hreflang">
    <link rel="alternate" hreflang="sv" href={new URL('/', Astro.site)} />
    <link rel="alternate" hreflang="en" href={new URL('/en/', Astro.site)} />
  </fragment>
  <fragment slot="jsonld">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": `${Astro.site}#website`,
          "url": Astro.site,
          "name": "Music Hub West",
          "inLanguage": "en-GB",
          "description": "A platform for the music industry's growth in Western Sweden."
        },
        {
          "@type": "Organization",
          "@id": `${Astro.site}#organization`,
          "name": "Music Hub West",
          "url": Astro.site,
          "logo": {
            "@type": "ImageObject",
            "url": new URL('/favicon.svg', Astro.site).toString()
          },
          "sameAs": []
        }
      ]
    })} />
  </fragment>
  <Nav lang={lang} active="start" />
  <section class="hero">
    <div class="hero__slides">
      {sorted.slice(0,4).map((ev, i) => (
        <div class={`hero__slide ${i===0?'active':''}`}>
          <div class="hero__slide-bg">
            <img src={ev.data.image} alt=""
              fetchpriority={i === 0 ? 'high' : undefined}
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding="async" />
          </div>
          <div class="hero__slide-content">
            <h1 class="hero__title" data-text={ev.data.title}>{ev.data.title}</h1>
            <p class="hero__subtitle">{ev.data.date} at {ev.data.location}</p>
            <div class="hero__controls">
              <div class="hero__dots" role="tablist" aria-label="Slideshow">
                {sorted.slice(0,4).map((_,j) => <button class={`hero__dot ${j===i?'active':''}`} role="tab" aria-label={`Slide ${j + 1}`} aria-selected={j===i?'true':'false'}></button>)}
              </div>
              <a href={`/en/events/${ev.id.replace('en/','')}`} class="btn btn--primary">Register now</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
  <section class="section"><div class="section__inner">
    <div class="section__head">
      <h2 class="section__title">Upcoming events</h2>
      <a href="/en/events" class="section__link">See all →</a>
    </div>
    <div class="card-grid">
      {sorted.slice(0,3).map(ev => (
        <EventCard title={ev.data.title} date={ev.data.date} time={ev.data.time}
          category={ev.data.category} image={ev.data.image}
          slug={ev.id.replace('en/','')} lang={lang} />
      ))}
    </div>
  </div></section>
  <div class="divider-wave">
    <svg viewBox="0 0 1440 40" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,20 C120,40 240,0 360,20 C480,40 600,0 720,20 C840,40 960,0 1080,20 C1200,40 1320,0 1440,20" stroke="#ccff00" stroke-width="3" fill="none"/>
    </svg>
  </div>

  <section class="section"><div class="section__inner">
    <div class="section__head">
      <h2 class="section__title">News & articles</h2>
      <a href="/en/articles" class="section__link">See all →</a>
    </div>
    <div class="card-grid">
      {latestArticles.map(a => (
        <ArticleCard
          title={a.data.title}
          author={a.data.author}
          date={a.data.date}
          category={a.data.category}
          description={a.body?.slice(0, 120).replace(/\s+/g, ' ').trim()}
          slug={a.id.replace('en/', '')}
          lang={lang}
        />
      ))}
    </div>
  </div></section>

  <div class="home-project">
    <div class="home-project__inner">
      <div class="home-project__header">
        <p class="home-project__kicker">Project 2026–2029</p>
        <h2 class="home-project__title">Tune In West</h2>
        <p class="home-project__text">Tune In West is a time-limited project aimed at strengthening the music industry's infrastructure and growth in Västra Götaland. The project consists of three parts offering different types of support and inspiration.</p>
      </div>
      <div class="home-ap-grid">
        <a href="/en/tune-in-west/music-hub" class="home-ap-card">
          <span class="home-ap-card__num">Events & inspiration</span>
          <h3 class="home-ap-card__title">Music Hub</h3>
          <p class="home-ap-card__desc">Recurring industry meetups, seminars and showcase events. Each year the Music Tech Hub Summit is held — the region's major meeting place for technology and music.</p>
          <span class="home-ap-card__link">Read more →</span>
        </a>
        <a href="/en/tune-in-west/musik-och-ai" class="home-ap-card">
          <span class="home-ap-card__num">Research & future</span>
          <h3 class="home-ap-card__title">Music and AI</h3>
          <p class="home-ap-card__desc">Research and knowledge development on AI's role in music creation and copyright. Academia and industry organisations collaborate to openly share new knowledge.</p>
          <span class="home-ap-card__link">Read more →</span>
        </a>
        <a href="/en/tune-in-west/kunskapsbyggande" class="home-ap-card">
          <span class="home-ap-card__num">Support & development</span>
          <h3 class="home-ap-card__title">Knowledge Building</h3>
          <p class="home-ap-card__desc">Concrete support for artists and music businesses — LEAN workshops, mentorship, an international study trip and a thinktank.</p>
          <span class="home-ap-card__link">Read more →</span>
        </a>
      </div>
    </div>
  </div>

  <Footer lang={lang} />
</Base>
