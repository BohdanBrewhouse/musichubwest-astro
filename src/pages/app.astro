---
// src/pages/app.astro
// PWA shell — standalone app feel
---
<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Music Hub West App</title>
  <meta name="theme-color" content="#0a0a0a" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Music Hub West" />
  <link rel="manifest" href="/manifest.json" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" sizes="180x180" href="/icon-180.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap" />
</head>
<body>

<!-- APP SHELL -->
<div class="app">

  <!-- Header -->
  <header class="app-header">
    <div class="app-header__inner">
      <span class="app-header__logo">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#c4ff00" stroke-width="2"/><path d="M9 8l8 4-8 4V8z" fill="#c4ff00"/></svg>
        Music Hub West
      </span>
      <button class="app-header__notify" id="app-notify-btn" title="Aktivera notiser">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </header>

  <!-- Install banner -->
  <div class="install-banner" id="install-banner" hidden>
    <p class="install-banner__text">📲 Lägg till på hemskärmen för bästa upplevelsen</p>
    <button class="install-banner__btn" id="install-btn">Installera</button>
    <button class="install-banner__close" id="install-close">✕</button>
  </div>

  <!-- Tab content -->
  <main class="app-main">

    <!-- TAB: FEED -->
    <section class="app-tab active" id="tab-feed">
      <div class="feed">

        <!-- Upcoming events -->
        <div class="feed-section">
          <h2 class="feed-section__title">Kommande event</h2>
          <div class="feed-events" id="feed-events">
            <!-- Placeholder cards -->
            <div class="event-card">
              <div class="event-card__date">
                <span class="event-card__day">15</span>
                <span class="event-card__month">MAJ</span>
              </div>
              <div class="event-card__info">
                <p class="event-card__title">Music Tech Hub Summit</p>
                <p class="event-card__meta">Brewhouse Inkubator · 10:00–17:00</p>
              </div>
              <button class="event-card__save" data-event="music-tech-hub-summit" title="Spara event">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Announcements feed -->
        <div class="feed-section">
          <h2 class="feed-section__title">Meddelanden</h2>
          <div class="feed-announcements" id="feed-announcements">
            <div class="announcement-card">
              <span class="announcement-card__tag">Info</span>
              <p class="announcement-card__title">Välkommen till Music Hub West App</p>
              <p class="announcement-card__body">Här hittar du agenda, spikernformation och uppdateringar direkt från arrangören.</p>
              <span class="announcement-card__date">Idag</span>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- TAB: AGENDA -->
    <section class="app-tab" id="tab-agenda">
      <div class="agenda-app">
        <div class="agenda-app__header">
          <h2 class="agenda-app__title">Dagens agenda</h2>
          <p class="agenda-app__date" id="agenda-date"></p>
        </div>

        <div class="agenda-sessions" id="agenda-sessions">
          <!-- Example sessions — will be replaced with real data -->
          <div class="session-card" data-time="10:00">
            <div class="session-card__time">
              <span class="session-card__start">10:00</span>
              <span class="session-card__end">10:30</span>
            </div>
            <div class="session-card__body">
              <span class="session-card__type session-card__type--keynote">Keynote</span>
              <p class="session-card__title">Öppningstal: Framtidens musikbransch</p>
              <p class="session-card__speaker">Anna Lindqvist · Stora scenen</p>
            </div>
            <button class="session-card__remind" data-time="10:00" title="Påminn mig">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>

          <div class="session-card" data-time="10:30">
            <div class="session-card__time">
              <span class="session-card__start">10:30</span>
              <span class="session-card__end">11:30</span>
            </div>
            <div class="session-card__body">
              <span class="session-card__type session-card__type--talk">Talk</span>
              <p class="session-card__title">AI och musikskapande — möjligheter och risker</p>
              <p class="session-card__speaker">HSM · Workshop-rummet</p>
            </div>
            <button class="session-card__remind" data-time="10:30" title="Påminn mig">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>

          <div class="session-card" data-time="11:30">
            <div class="session-card__time">
              <span class="session-card__start">11:30</span>
              <span class="session-card__end">12:00</span>
            </div>
            <div class="session-card__body">
              <span class="session-card__type session-card__type--break">Paus</span>
              <p class="session-card__title">Fika & networking</p>
              <p class="session-card__speaker">Foajén</p>
            </div>
            <button class="session-card__remind" data-time="11:30" title="Påminn mig">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>

          <div class="session-card" data-time="12:00">
            <div class="session-card__time">
              <span class="session-card__start">12:00</span>
              <span class="session-card__end">13:00</span>
            </div>
            <div class="session-card__body">
              <span class="session-card__type session-card__type--panel">Panel</span>
              <p class="session-card__title">Upphovsrätt i AI-eran</p>
              <p class="session-card__speaker">3 talare · Stora scenen</p>
            </div>
            <button class="session-card__remind" data-time="12:00" title="Påminn mig">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- TAB: SPEAKERS -->
    <section class="app-tab" id="tab-speakers">
      <div class="speakers-app">
        <div class="speakers-app__header">
          <h2 class="speakers-app__title">Talare</h2>
          <p class="speakers-app__sub">Klicka för mer info & sociala länkar</p>
        </div>
        <div class="speakers-grid" id="speakers-grid">
          <!-- Example speaker cards -->
          <div class="speaker-card" data-speaker="anna-lindqvist">
            <div class="speaker-card__photo speaker-card__photo--placeholder">AL</div>
            <div class="speaker-card__info">
              <p class="speaker-card__name">Anna Lindqvist</p>
              <p class="speaker-card__role">CEO · Spotify Nordic</p>
            </div>
            <svg class="speaker-card__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>

          <div class="speaker-card" data-speaker="marcus-berg">
            <div class="speaker-card__photo speaker-card__photo--placeholder">MB</div>
            <div class="speaker-card__info">
              <p class="speaker-card__name">Marcus Berg</p>
              <p class="speaker-card__role">Forskare · HSM</p>
            </div>
            <svg class="speaker-card__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
        </div>
      </div>
    </section>

  </main>

  <!-- Bottom tab bar -->
  <nav class="app-tabs">
    <button class="app-tab-btn active" data-tab="feed">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span>Feed</span>
    </button>
    <button class="app-tab-btn" data-tab="agenda">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke="currentColor" stroke-width="1.8"/><line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="1.8"/></svg>
      <span>Agenda</span>
    </button>
    <button class="app-tab-btn" data-tab="speakers">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.8"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span>Talare</span>
    </button>
  </nav>

</div>

<script is:inline>
(function() {
  // ── Service Worker ──
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/sw.js');
  }

  // ── Tab navigation ──
  var tabBtns = document.querySelectorAll('.app-tab-btn');
  var tabPanels = document.querySelectorAll('.app-tab');
  tabBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = btn.getAttribute('data-tab');
      tabBtns.forEach(function(b) { b.classList.remove('active'); });
      tabPanels.forEach(function(p) { p.classList.remove('active'); });
      btn.classList.add('active');
      document.getElementById('tab-' + tab).classList.add('active');
    });
  });

  // ── Agenda date ──
  var agendaDate = document.getElementById('agenda-date');
  if (agendaDate) {
    var d = new Date();
    agendaDate.textContent = d.toLocaleDateString('sv-SE', { weekday: 'long', day: 'numeric', month: 'long' });
  }

  // ── Push notifications ──
  var notifyBtn = document.getElementById('app-notify-btn');
  if (notifyBtn) {
    notifyBtn.addEventListener('click', function() {
      if (!('Notification' in window)) {
        alert('Din webbläsare stöder inte notiser.');
        return;
      }
      Notification.requestPermission().then(function(perm) {
        if (perm === 'granted') {
          notifyBtn.style.color = '#c4ff00';
          // Register push subscription
          if ('serviceWorker' in navigator && 'PushManager' in window) {
            navigator.serviceWorker.ready.then(function(registration) {
              subscribeToPush(registration);
            });
          }
        }
      });
    });
  }

  async function subscribeToPush(registration) {
    try {
      var sub = await registration.pushManager.subscribe({
        userVisibleOnly: true,
        applicationServerKey: 'BECsIxXMry_mE5aVJlusGsoW_BtyvvleM5PZDnLLZwQN68ee4sH9pxTRfW80Hsu3QbcxOmbhuhQelLLLCCJyLbU'
      });
      await fetch('/api/app/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ subscription: sub })
      });
    } catch (e) {
      console.warn('Push subscription failed:', e);
    }
  }

  // ── Remind me listeners (also called after dynamic render) ──
  function attachRemindListeners() {
    document.querySelectorAll('.session-card__remind').forEach(function(btn) {
      var savedKey = 'remind-' + btn.getAttribute('data-time');
      if (localStorage.getItem(savedKey)) {
        btn.classList.add('active');
      }
      // Remove old listener by cloning
      var newBtn = btn.cloneNode(true);
      btn.parentNode.replaceChild(newBtn, btn);
      if (localStorage.getItem(savedKey)) {
        newBtn.classList.add('active');
      }
      newBtn.addEventListener('click', function() {
        var time = newBtn.getAttribute('data-time');
        var key = 'remind-' + time;
        if (localStorage.getItem(key)) {
          localStorage.removeItem(key);
          newBtn.classList.remove('active');
        } else {
          localStorage.setItem(key, '1');
          newBtn.classList.add('active');
          if (Notification.permission === 'granted') {
            new Notification('Påminnelse sparad! 🔔', { body: 'Vi påminner dig 15 min före ' + time, icon: '/favicon.svg' });
          }
        }
      });
    });
  }

  // Initial remind listeners for static cards
  attachRemindListeners();

  // ── Save event button ──
  document.querySelectorAll('.event-card__save').forEach(function(btn) {
    var eventId = btn.getAttribute('data-event');
    var key = 'saved-' + eventId;
    if (localStorage.getItem(key)) btn.classList.add('active');
    btn.addEventListener('click', function() {
      if (localStorage.getItem(key)) {
        localStorage.removeItem(key);
        btn.classList.remove('active');
      } else {
        localStorage.setItem(key, '1');
        btn.classList.add('active');
      }
    });
  });

  // ── PWA Install banner ──
  var deferredPrompt;
  var banner = document.getElementById('install-banner');
  var installBtn = document.getElementById('install-btn');
  var closeBtn = document.getElementById('install-close');

  window.addEventListener('beforeinstallprompt', function(e) {
    e.preventDefault();
    deferredPrompt = e;
    if (banner && !localStorage.getItem('install-dismissed')) {
      banner.hidden = false;
    }
  });

  if (installBtn) {
    installBtn.addEventListener('click', function() {
      if (deferredPrompt) {
        deferredPrompt.prompt();
        deferredPrompt.userChoice.then(function() {
          deferredPrompt = null;
          banner.hidden = true;
        });
      }
    });
  }

  if (closeBtn) {
    closeBtn.addEventListener('click', function() {
      banner.hidden = true;
      localStorage.setItem('install-dismissed', '1');
    });
  }

  // ── Dynamic data from Edge Config ──
  fetch('/api/app/data')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.agenda && data.agenda.length) renderAgenda(data.agenda);
      if (data.speakers && data.speakers.length) renderSpeakers(data.speakers);
      if (data.announcements && data.announcements.length) renderAnnouncements(data.announcements);
    })
    .catch(function() {}); // keep placeholders on error

  function renderAgenda(sessions) {
    var container = document.getElementById('agenda-sessions');
    if (!container) return;
    container.innerHTML = sessions
      .slice()
      .sort(function(a, b) { return (a.start_time || '').localeCompare(b.start_time || ''); })
      .map(function(s) {
        var type = (s.type || 'talk').toLowerCase();
        return (
          '<div class="session-card" data-time="' + escHtml(s.start_time || '') + '">' +
            '<div class="session-card__time">' +
              '<span class="session-card__start">' + escHtml(s.start_time || '') + '</span>' +
              '<span class="session-card__end">' + escHtml(s.end_time || '') + '</span>' +
            '</div>' +
            '<div class="session-card__body">' +
              '<span class="session-card__type session-card__type--' + type + '">' + escHtml(s.type || 'Talk') + '</span>' +
              '<p class="session-card__title">' + escHtml(s.title || '') + '</p>' +
              '<p class="session-card__speaker">' + escHtml([s.speaker_name, s.location].filter(Boolean).join(' \xB7 ')) + '</p>' +
            '</div>' +
            '<button class="session-card__remind" data-time="' + escHtml(s.start_time || '') + '" title="P\xE5minn mig">' +
              '<svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>' +
            '</button>' +
          '</div>'
        );
      })
      .join('');
    attachRemindListeners();
  }

  function renderSpeakers(speakers) {
    var container = document.getElementById('speakers-grid');
    if (!container) return;
    container.innerHTML = speakers.map(function(s) {
      var initials = (s.name || '?').split(' ').map(function(w) { return w[0] || ''; }).join('').slice(0, 2).toUpperCase();
      return (
        '<div class="speaker-card" onclick="openSpeaker(\'' + escHtml(s.id || '') + '\')">' +
          '<div class="speaker-card__photo speaker-card__photo--placeholder">' + escHtml(initials) + '</div>' +
          '<div class="speaker-card__info">' +
            '<p class="speaker-card__name">' + escHtml(s.name || '') + '</p>' +
            '<p class="speaker-card__role">' + escHtml([s.title, s.company].filter(Boolean).join(' \xB7 ')) + '</p>' +
          '</div>' +
          '<svg class="speaker-card__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>' +
        '</div>'
      );
    }).join('');
  }

  function renderAnnouncements(items) {
    var container = document.getElementById('feed-announcements');
    if (!container) return;
    var sorted = items.slice().sort(function(a, b) {
      return (b.pinned ? 1 : 0) - (a.pinned ? 1 : 0);
    });
    container.innerHTML = sorted.map(function(a) {
      return (
        '<div class="announcement-card">' +
          '<span class="announcement-card__tag">' + escHtml(a.category || 'Info') + '</span>' +
          '<p class="announcement-card__title">' + escHtml(a.title || '') + '</p>' +
          '<p class="announcement-card__body">' + escHtml(a.body || '') + '</p>' +
          '<span class="announcement-card__date">' + escHtml(a.date || '') + '</span>' +
        '</div>'
      );
    }).join('');
  }

  function escHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  // Placeholder for speaker modal (can be extended later)
  window.openSpeaker = function(id) {
    console.log('openSpeaker', id);
  };

})();
</script>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --black: #0a0a0a;
    --black-2: #111;
    --black-3: rgba(255,255,255,0.08);
    --white: #fff;
    --lime: #c4ff00;
    --font: 'Outfit', sans-serif;
  }

  html, body {
    height: 100%;
    background: var(--black);
    color: var(--white);
    font-family: var(--font);
    overflow: hidden;
  }

  .app {
    display: flex;
    flex-direction: column;
    height: 100dvh;
    height: 100vh;
    max-width: 480px;
    margin: 0 auto;
    position: relative;
  }

  /* ── Header ── */
  .app-header {
    background: var(--black);
    border-bottom: 1px solid var(--black-3);
    padding: env(safe-area-inset-top, 0) 0 0;
    flex-shrink: 0;
    z-index: 10;
  }
  .app-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
  }
  .app-header__logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 700;
    color: var(--white);
  }
  .app-header__notify {
    background: none;
    border: none;
    color: rgba(255,255,255,0.5);
    cursor: pointer;
    padding: 4px;
    transition: color 0.2s;
  }
  .app-header__notify:hover { color: var(--lime); }

  /* ── Install banner ── */
  .install-banner {
    background: rgba(196,255,0,0.08);
    border-bottom: 1px solid rgba(196,255,0,0.2);
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  .install-banner__text { font-size: 12px; color: rgba(255,255,255,0.8); flex: 1; }
  .install-banner__btn {
    background: var(--lime);
    color: var(--black);
    border: none;
    border-radius: 4px;
    padding: 5px 12px;
    font-size: 12px;
    font-weight: 700;
    font-family: var(--font);
    cursor: pointer;
    white-space: nowrap;
  }
  .install-banner__close {
    background: none;
    border: none;
    color: rgba(255,255,255,0.4);
    cursor: pointer;
    font-size: 14px;
    padding: 2px;
  }

  /* ── Main scroll area ── */
  .app-main {
    flex: 1;
    overflow: hidden;
    position: relative;
  }

  .app-tab {
    display: none;
    height: 100%;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  .app-tab.active { display: block; }

  /* ── Bottom tab bar ── */
  .app-tabs {
    display: flex;
    border-top: 1px solid var(--black-3);
    background: var(--black);
    padding-bottom: env(safe-area-inset-bottom, 0);
