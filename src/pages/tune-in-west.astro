---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const lang = 'sv';
---
<Base title="Tune In West – Music Hub West" lang={lang} description="Tune In West är ett projekt 2026–2029 för att stärka musikindustrins infrastruktur i Västra Götaland.">
 <fragment slot="hreflang">
 <link rel="alternate" hreflang="sv" href={new URL('/tune-in-west', Astro.site)} />
 <link rel="alternate" hreflang="en" href={new URL('/en/tune-in-west', Astro.site)} />
 </fragment>

 <Nav lang={lang} />

 <!-- HERO -->
 <div class="tiw-hero">
 <div class="tiw-hero__inner">
 <p class="tiw-hero__kicker">Projekt 2026–2029</p>
 <h1 class="tiw-hero__title">Tune in<br>West</h1>
 <p class="tiw-hero__text">Med finansiering från Tillväxtverket, Västra Götalandsregionen, Högskolan för Scen och Musik samt Brewhouse Inkubator skapas förutsättningar för musikindustrins tillväxt inom Västra Götaland.</p>
 <a href="/om" class="tiw-hero__link">Kontakta oss →</a>
 </div>
 </div>

 <!-- STATS -->
 <div class="tiw-stats">
 <div class="tiw-stats__inner">
 <p class="tiw-stats__title">Projektet i siffror</p>
 <div class="tiw-stats__grid">
 <div>
 <p class="tiw-stat__number" data-count="45">45</p>
 <p class="tiw-stat__label">deltagande bolag</p>
 </div>
 <div>
 <p class="tiw-stat__number">3 mkr</p>
 <p class="tiw-stat__label">i finansiering</p>
 </div>
 <div>
 <p class="tiw-stat__number" data-count="12">12+</p>
 <p class="tiw-stat__label">event per år</p>
 </div>
 </div>
 </div>
 </div>

 <!-- ABOUT -->
 <div class="tiw-about">
 <div>
 <h2 class="tiw-about__title">Vad är Tune In West?</h2>
 <p class="tiw-about__text">Tune In West är ett tidsbegränsat projekt (2026–2029) med syfte att stärka musikindustrins infrastruktur och tillväxt i Västra Götaland.</p>
 <p class="tiw-about__text">Projektet finansieras gemensamt av Tillväxtverket, Västra Götalandsregionen, Högskolan för Scen och Musik samt Brewhouse Inkubator — och drivs genom plattformen Music Hub West.</p>
 <p class="tiw-about__text">Tune In West är avsändare och medarrangör för en rad aktiviteter inom ramen för Music Hub West — men Music Hub West är en öppen plattform för hela branschen.</p>
 <a href="/om" class="btn btn--outline" style="margin-top:16px">Läs mer om oss</a>
 </div>
 <div>
 <h2 class="tiw-about__title">Vad gör vi?</h2>
 <div class="ap-cards">
 <a href="/tune-in-west/music-hub" class="ap-card">
 <span class="ap-card__num">AP 1</span>
 <h3 class="ap-card__title">Music Hub</h3>
 <p class="ap-card__desc">En samlande plattform för musikbranschens aktörer i Västsverige – branschträffar, showcases och ett årligt Music Tech Hub Summit.</p>
 <span class="ap-card__link">Läs mer →</span>
 </a>
 <a href="/tune-in-west/musik-och-ai" class="ap-card">
 <span class="ap-card__num">AP 2</span>
 <h3 class="ap-card__title">Musik och AI</h3>
 <p class="ap-card__desc">Forskning och kunskapsutveckling kring AI:s roll i musikskapande, upphovsrätt och hållbara intäktsmodeller.</p>
 <span class="ap-card__link">Läs mer →</span>
 </a>
 <a href="/tune-in-west/kunskapsbyggande" class="ap-card">
 <span class="ap-card__num">AP 3</span>
 <h3 class="ap-card__title">Kunskapsbyggande</h3>
 <p class="ap-card__desc">Konkret stöd för små och medelstora musikföretag – LEAN-metodik, mentorskap, studieresa och thinktank.</p>
 <span class="ap-card__link">Läs mer →</span>
 </a>
 </div>
 </div>
 </div>

 <!-- PARTNERS -->
 <div class="tiw-partners">
 <div class="tiw-partners__inner">
 <p class="tiw-partners__title">Finansieras av</p>
 <div class="partner-logos">
 <span class="partner-logo"><img src="/logos/vgr.svg" alt="Västra Götalandsregionen" /></span>
 <span class="partner-logo"><img src="/logos/tillvaxtverket.svg" alt="Tillväxtverket" /></span>
 <span class="partner-logo"><img src="/logos/brewhouse.svg" alt="Brewhouse Inkubator" /></span>
 <span class="partner-logo"><img src="/logos/hsm.svg" alt="Högskolan för scen och musik" /></span>
 </div>
 </div>
 </div>

 <!-- CONTACT -->
 <div class="tiw-contact">
 <div class="tiw-contact__inner">
 <div>
 <p class="tiw-contact__kicker">Kontakt</p>
 <h2 class="tiw-contact__title">Kontakta Tune In West</h2>
 <p class="tiw-contact__text">Har du frågor om projektet, vill veta mer om hur du kan delta eller är intresserad av ett samarbete? Hör av dig till oss direkt eller fyll i formuläret.</p>
 <div class="tiw-contact__people">
 <div class="tiw-contact__person">
 <div class="tiw-contact__avatar"></div>
 <div>
 <p class="tiw-contact__name">Angelica Kranz</p>
 <p class="tiw-contact__role">Projektledare · Tune In West</p>
 <a href="mailto:angelica@brewhouse.se" class="tiw-contact__email">angelica@brewhouse.se</a>
 </div>
 </div>
 <div class="tiw-contact__person">
 <div class="tiw-contact__avatar"></div>
 <div>
 <p class="tiw-contact__name">Johan Brewhouse</p>
 <p class="tiw-contact__role">Kommunikationsansvarig · Music Hub West</p>
 <a href="mailto:johan@brewhouse.se" class="tiw-contact__email">johan@brewhouse.se</a>
 </div>
 </div>
 </div>
 </div>
 <div class="tiw-form">
 <p class="tiw-form__title">Skicka ett meddelande</p>
 <form>
 <div class="tiw-form__row">
 <div class="form__group">
 <label class="form__label" for="tiw-name">Namn</label>
 <input class="form__input" type="text" id="tiw-name" placeholder="Ditt namn" />
 </div>
 <div class="form__group">
 <label class="form__label" for="tiw-org">Organisation</label>
 <input class="form__input" type="text" id="tiw-org" placeholder="Företag / Organisation" />
 </div>
 </div>
 <div class="form__group">
 <label class="form__label" for="tiw-email">E-post</label>
 <input class="form__input" type="email" id="tiw-email" placeholder="din@email.se" />
 </div>
 <div class="form__group">
 <label class="form__label" for="tiw-msg">Meddelande</label>
 <textarea class="form__textarea" id="tiw-msg" placeholder="Vad kan vi hjälpa dig med?" style="height:130px;"></textarea>
 </div>
 <button type="submit" class="btn btn--primary" style="width:100%;justify-content:center;">Skicka meddelande</button>
 </form>
 </div>
 </div>
 </div>

 <Footer lang={lang} />
</Base>

<style>
 .tiw-hero {
 background: var(--black);
 color: var(--white);
 padding: 88px 40px 80px;
 position: relative;
 overflow: hidden;
 }
 .tiw-hero::before {
 content: '';
 position: absolute;
 top: -120px; right: -120px;
 width: 700px; height: 700px;
 background: var(--lime);
 opacity: 0.12;
 border-radius: 50%;
 pointer-events: none;
 }
 .tiw-hero__inner {
 max-width: var(--max);
 margin: 0 auto;
 position: relative;
 z-index: 1;
 }
 .tiw-hero__kicker {
 font-size: 11px;
 font-weight: 800;
 letter-spacing: 0.12em;
 text-transform: uppercase;
 color: var(--lime);
 margin-bottom: 20px;
 }
 .tiw-hero__title {
 font-size: clamp(52px, 9vw, 120px);
 font-weight: 800;
 letter-spacing: -0.045em;
 line-height: 0.92;
 margin-bottom: 32px;
 }
 .tiw-hero__text {
 font-size: 18px;
 color: rgba(255,255,255,0.72);
 max-width: 560px;
 line-height: 1.6;
 margin-bottom: 36px;
 }
 .tiw-hero__link {
 font-size: 15px;
 font-weight: 700;
 color: var(--white);
 text-decoration: underline;
 text-underline-offset: 4px;
 }
 .tiw-stats {
 background: var(--lime);
 padding: 72px 40px;
 }
 .tiw-stats__inner { max-width: var(--max); margin: 0 auto; }
 .tiw-stats__title {
 font-size: 13px;
 font-weight: 800;
 letter-spacing: 0.1em;
 text-transform: uppercase;
 margin-bottom: 48px;
 color: rgba(0,0,0,0.5);
 }
 .tiw-stats__grid {
 display: grid;
 grid-template-columns: repeat(3, 1fr);
 gap: 32px;
 }
 .tiw-stat__number {
 font-size: clamp(52px, 7vw, 88px);
 font-weight: 800;
 letter-spacing: -0.04em;
 line-height: 1;
 margin-bottom: 8px;
 color: var(--black);
 }
 .tiw-stat__label {
 font-size: 15px;
 font-weight: 600;
 color: var(--black);
 opacity: 0.65;
 }
 .tiw-about {
 padding: 80px 40px;
 max-width: var(--max);
 margin: 0 auto;
 display: grid;
 grid-template-columns: 1fr 1fr;
 gap: 80px;
 align-items: start;
 }
 .tiw-about > div:first-child {
   position: sticky;
   top: 100px;
 }
 .tiw-about__title {
 font-size: clamp(28px, 3.5vw, 48px);
 font-weight: 800;
 letter-spacing: -0.035em;
 line-height: 1.05;
 margin-bottom: 24px;
 }
 .tiw-about__text {
 font-size: 16px;
 color: rgba(255,255,255,0.75);
 line-height: 1.7;
 margin-bottom: 16px;
 }
 .tiw-partners {
 border-top: 1px solid var(--black-3);
 padding: 56px 40px;
 }
 .tiw-partners__inner { max-width: var(--max); margin: 0 auto; }
 .tiw-partners__title {
 font-size: 11px;
 font-weight: 800;
 letter-spacing: 0.1em;
 text-transform: uppercase;
 color: var(--grey-500);
 margin-bottom: 28px;
 }
 .tiw-contact {
 background: var(--black-2);
 border-top: 1px solid var(--black-3);
 padding: 80px 40px;
 }
 .tiw-contact__inner {
 max-width: var(--max);
 margin: 0 auto;
 display: grid;
 grid-template-columns: 1fr 1fr;
 gap: 80px;
 align-items: start;
 }
 .tiw-contact__kicker {
 font-size: 11px;
 font-weight: 800;
 letter-spacing: 0.12em;
 text-transform: uppercase;
 color: var(--lime);
 margin-bottom: 16px;
 }
 .tiw-contact__title {
 font-size: clamp(28px, 3.5vw, 44px);
 font-weight: 800;
 letter-spacing: -0.03em;
 line-height: 1.05;
 margin-bottom: 16px;
 color: var(--white);
 }
 .tiw-contact__text {
 font-size: 16px;
 color: rgba(255,255,255,0.6);
 line-height: 1.7;
 margin-bottom: 32px;
 max-width: 420px;
 }
 .tiw-contact__people { display: flex; flex-direction: column; gap: 20px; margin-top: 8px; }
 .tiw-contact__person {
 display: flex;
 align-items: center;
 gap: 16px;
 padding: 16px;
 border: 1px solid var(--black-3);
 background: var(--black);
 }
 .tiw-contact__avatar {
 width: 48px; height: 48px;
 background: var(--black-3);
 border-radius: 50%;
 flex-shrink: 0;
 }
 .tiw-contact__name { font-size: 14px; font-weight: 700; color: var(--white); margin-bottom: 2px; }
 .tiw-contact__role { font-size: 12px; color: rgba(255,255,255,0.4); margin-bottom: 4px; }
 .tiw-contact__email { font-size: 12px; color: var(--lime); font-weight: 600; text-decoration: underline; text-underline-offset: 3px; }
 .tiw-form {
 background: var(--black);
 border: 1px solid var(--black-3);
 padding: 40px;
 }
 .tiw-form__title {
 font-size: 20px;
 font-weight: 800;
 letter-spacing: -0.02em;
 margin-bottom: 28px;
 color: var(--white);
 }
 .tiw-form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

 /* AP cards */
 .ap-cards { display: flex; flex-direction: column; gap: 12px; }
 .ap-card {
 display: block;
 border: 1px solid var(--black-3);
 padding: 24px;
 text-decoration: none;
 color: var(--white);
 transition: border-color 0.2s, background 0.2s;
 background: transparent;
 }
 .ap-card:hover { border-color: var(--lime); background: rgba(208,255,0,0.04); }
 .ap-card__num {
 font-size: 10px;
 font-weight: 800;
 letter-spacing: 0.12em;
 text-transform: uppercase;
 color: var(--lime);
 margin-bottom: 8px;
 display: block;
 }
 .ap-card__title {
 font-size: 18px;
 font-weight: 800;
 letter-spacing: -0.02em;
 margin-bottom: 8px;
 color: var(--white);
 }
 .ap-card__desc {
 font-size: 14px;
 color: rgba(255,255,255,0.6);
 line-height: 1.6;
 margin-bottom: 16px;
 }
 .ap-card__link {
 font-size: 13px;
 font-weight: 700;
 color: var(--lime);
 }

 @media (max-width: 1024px) {
 .tiw-about { grid-template-columns: 1fr; gap: 48px; }
 .tiw-about > div:first-child { position: static; }
 .tiw-contact__inner { grid-template-columns: 1fr; gap: 48px; }
 }
 @media (max-width: 640px) {
 .tiw-hero { padding: 56px 20px 56px; }
 .tiw-stats { padding: 48px 20px; }
 .tiw-stats__grid { grid-template-columns: 1fr; gap: 32px; }
 .tiw-about { padding: 48px 20px; }
 .tiw-partners { padding: 40px 20px; }
 .tiw-contact { padding: 48px 20px; }
 .tiw-form { padding: 24px 20px; }
 .tiw-form__row { grid-template-columns: 1fr; }
 }
</style>
