---
import Base from '../../../layouts/Base.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import ShareBar from '../../../components/ShareBar.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles', a => a.id.startsWith('en/'));
  return articles.map(a => ({
    params: { slug: a.id.replace('en/', '') },
    props: { article: a },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const lang = 'en';

const svArticles = await getCollection('articles', a => a.id.startsWith('sv/'));
const svMatch = svArticles.find(a => a.data.translationKey === article.data.translationKey);
const altUrl = svMatch ? `/artiklar/${svMatch.id.replace('sv/', '')}` : '/artiklar';

const allEnArticles = await getCollection('articles', a => a.id.startsWith('en/'));
const relatedArticles = allEnArticles
  .filter(a => a.id !== article.id)
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .slice(0, 3);

const badgeClass: Record<string, string> = {
  'Tune In West': 'badge--tiw',
  'Kulturverkstaden': 'badge--kv',
  'Högskolan för scen och musik': 'badge--hsm',
  'VGR': 'badge--vgr',
};
---
<Base title={`${article.data.title} – Music Hub West`} lang={lang} description={article.body?.slice(0,155).replace(/\s+/g,' ').trim()}>
  <fragment slot="hreflang">
    <link rel="alternate" hreflang="en" href={new URL(`/en/articles/${article.id.replace('en/','')}`, Astro.site)} />
    {svMatch && <link rel="alternate" hreflang="sv" href={new URL(altUrl, Astro.site)} />}
  </fragment>
  <fragment slot="jsonld">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": article.data.title,
      "author": { "@type": "Person", "name": article.data.author },
      "datePublished": article.data.date,
      "publisher": { "@type": "Organization", "name": "Music Hub West", "url": Astro.site },
      "inLanguage": "en",
      "url": new URL(`/en/articles/${article.id.replace('en/','')}`, Astro.site).toString(),
    })} />
  </fragment>
  <Nav lang={lang} active="articles" altUrl={altUrl} />

  <div class="article-header">
    <a href="/en/articles" class="article-header__back">← All articles</a>
    <div class="article-header__badge">
      <span class={`badge ${badgeClass[article.data.category] ?? ''}`}>{article.data.category}</span>
    </div>
    <h1 class="article-header__title">{article.data.title}</h1>
    <div class="article-header__meta">
      <div class="article-header__author">
        <div class="article-header__avatar" aria-hidden="true"></div>
        <div>
          <p class="article-header__author-name">{article.data.author}</p>
        </div>
      </div>
      <span class="article-header__date">{article.data.date}</span>
    </div>
  </div>

  <ShareBar lang={lang} title={article.data.title} />

  {article.data.image && (
    <div class="article-image">
      <div class="article-image__inner">
        <img src={article.data.image} alt={article.data.title} />
      </div>
    </div>
  )}

  <div class="article-body">
    <Content />
  </div>

  {relatedArticles.length > 0 && (
    <div class="related">
      <div class="related__inner">
        <h2 class="related__title">More articles</h2>
        <div class="card-grid">
          {relatedArticles.map(a => (
            <ArticleCard
              title={a.data.title}
              author={a.data.author}
              date={a.data.date}
              category={a.data.category}
              description={a.body?.slice(0, 110).replace(/\s+/g, ' ').trim() + '...'}
              slug={a.id.replace('en/', '')}
              lang={lang}
            />
          ))}
        </div>
      </div>
    </div>
  )}

  <Footer lang={lang} />
</Base>
