---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const lang = 'en';
---
<Base title="About – Music Hub West" lang={lang} description="Music Hub West is your meeting place for music, networking and new ideas in Western Sweden. Events, masterclasses and a community built for musicians, producers and creatives.">
  <fragment slot="hreflang">
    <link rel="alternate" hreflang="sv" href={new URL('/om', Astro.site)} />
    <link rel="alternate" hreflang="en" href={new URL('/en/about', Astro.site)} />
  </fragment>
  <fragment slot="jsonld">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": Astro.site },
        { "@type": "ListItem", "position": 2, "name": "About", "item": new URL('/en/about', Astro.site).toString() }
      ]
    })} />
  </fragment>

  <Nav lang={lang} active="about" />

  <!-- TAB NAVIGATION -->
  <div class="page-tabs">
    <div class="page-tabs__inner">
      <button class="page-tab active" data-tab="om-oss">About us</button>
      <button class="page-tab" data-tab="kontakt">Contact</button>
      <button class="page-tab" data-tab="partners">Partners</button>
    </div>
  </div>

  <!-- PANEL: ABOUT -->
  <div class="page-panel active" id="tab-om-oss">

    <!-- HERO -->
    <div class="about-hero">
      <div class="about-hero__inner">
        <p class="about-hero__kicker">About the platform</p>
        <h1 class="about-hero__title">Music Hub<br>West</h1>
        <p class="about-hero__subtitle">Your meeting place for music, networking and new ideas. In Western Sweden.</p>
      </div>
    </div>

    <!-- IMAGE -->
    <div class="about-image brand-photo">
      <img src="/images/about-hero.png" alt="Gothenburg" />
      <div class="about-image__overlay"></div>
    </div>

    <!-- PLATFORM -->
    <div class="about-platform">
      <div class="about-platform__inner">
        <div class="about-platform__text">
          <p class="about-section__kicker">The platform</p>
          <h2 class="about-section__title">What is Music Hub West?</h2>
          <p class="about-body">Music Hub West is an open community for anyone working with music in Western Sweden. Musicians, producers, creatives and event organisers meet here to network, learn new things and find their next collaboration.</p>
          <p class="about-body">We run events, masterclasses, think tanks and a Tech Summit. You sign up and show up. Simple as that.</p>
          <p class="about-body">It doesn't matter if you're a solo artist or run a company. If you work with music in any way, you're welcome here.</p>
        </div>
        <div class="about-platform__highlight">
          <blockquote class="about-quote">
            <p>"Music doesn't happen in a vacuum. The best things happen when the right people meet in the right place."</p>
          </blockquote>
          <div class="about-stats-mini">
            <div class="about-stat">
              <span class="about-stat__num">45</span>
              <span class="about-stat__label">participating companies</span>
            </div>
            <div class="about-stat">
              <span class="about-stat__num">3 MSEK</span>
              <span class="about-stat__label">in funding</span>
            </div>
            <div class="about-stat">
              <span class="about-stat__num">12+</span>
              <span class="about-stat__label">events per year</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- PROJECT -->
    <div class="about-project">
      <div class="about-project__inner">
        <div class="about-project__header">
          <p class="about-section__kicker">Project 2026–2029</p>
          <h2 class="about-section__title">Tune In West</h2>
          <p class="about-body" style="max-width:640px;">Tune In West is the project behind Music Hub West. An investment in the music industry in Western Sweden running until 2029, backed by Tillväxtverket, VGR, Högskolan för scen och musik and Brewhouse Inkubator.</p>
        </div>
        <a href="https://tuneinwest.se/en" target="_blank" rel="noopener" class="home-project__btn">
          Visit the project website →
        </a>
      </div>
    </div>

    <!-- THEMES -->
    <div class="about-themes">
      <div class="about-themes__inner">
        <p class="about-section__kicker">Focus areas</p>
        <div class="about-themes__grid">
          <div class="about-theme">
            <div class="about-theme__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="var(--lime)" stroke-width="2" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="var(--lime)" stroke-width="2"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="var(--lime)" stroke-width="2" stroke-linecap="round"/></svg>
            </div>
            <h3 class="about-theme__title">Collaboration &amp; networks</h3>
            <p class="about-theme__desc">You meet people you wouldn't have found otherwise. Artists, tech companies, event organisers and cultural institutions. All in one place, in your region.</p>
          </div>
          <div class="about-theme">
            <div class="about-theme__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5z" stroke="var(--lime)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5" stroke="var(--lime)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="about-theme__title">AI &amp; digitalisation</h3>
            <p class="about-theme__desc">What happens to your music when AI takes over? We dig into both the opportunities and the questions. Creative practice, production and copyright.</p>
          </div>
          <div class="about-theme">
            <div class="about-theme__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22V12M12 12L6 6M12 12l6-6M2 22h20" stroke="var(--lime)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="about-theme__title">Sustainable growth</h3>
            <p class="about-theme__desc">We give you the tools to grow. Business models that last, international perspectives and a network that actually opens doors.</p>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- PANEL: CONTACT -->
  <div class="page-panel" id="tab-kontakt">
    <div class="contact-layout">
      <div>
        <h2 class="contact-title">Contact us</h2>
        <p class="contact-subtitle">Questions about events, collaborations or the project? Get in touch and we'll get back to you.</p>
        <div class="team-grid">
          <div class="team-card">
            <div class="team-card__photo"></div>
            <p class="team-card__name">Angelica</p>
            <p class="team-card__org">Brewhouse</p>
            <p class="team-card__email">angelica@brewhouse.se</p>
          </div>
          <div class="team-card">
            <div class="team-card__photo"></div>
            <p class="team-card__name">Johan</p>
            <p class="team-card__org">Brewhouse</p>
            <p class="team-card__email">johan@brewhouse.se</p>
          </div>
          <div class="team-card">
            <div class="team-card__photo"></div>
            <p class="team-card__name">Charlotte</p>
            <p class="team-card__org">Brewhouse</p>
            <p class="team-card__email">charlotte@brewhouse.se</p>
          </div>
          <div class="team-card">
            <div class="team-card__photo"></div>
            <p class="team-card__name">Erik</p>
            <p class="team-card__org">Högskolan för scen och musik</p>
            <p class="team-card__email">erik@hsm.se</p>
          </div>
          <div class="team-card">
            <div class="team-card__photo"></div>
            <p class="team-card__name">Jonathan</p>
            <p class="team-card__org">VGR</p>
            <p class="team-card__email">jonathan@vgr.se</p>
          </div>
          <div class="team-card">
            <div class="team-card__photo"></div>
            <p class="team-card__name">Maja-Karin</p>
            <p class="team-card__org">VGR</p>
            <p class="team-card__email">maja-karin@vgr.se</p>
          </div>
        </div>
      </div>
      <div>
        <div class="form-block__title">Send a message</div>
        <form>
          <div class="form__group">
            <label class="form__label" for="name">Name</label>
            <input class="form__input" type="text" id="name" placeholder="Your name" />
          </div>
          <div class="form__group">
            <label class="form__label" for="email">Email</label>
            <input class="form__input" type="email" id="email" placeholder="your@email.com" />
          </div>
          <div class="form__group">
            <label class="form__label" for="org">Organisation</label>
            <input class="form__input" type="text" id="org" placeholder="Company / Organisation" />
          </div>
          <div class="form__group">
            <label class="form__label" for="msg">Message</label>
            <textarea class="form__textarea" id="msg" placeholder="How can we help you?"></textarea>
          </div>
          <button type="submit" class="btn btn--primary" style="width:100%">Send</button>
        </form>
      </div>
    </div>
  </div>

  <!-- PANEL: PARTNERS -->
  <div class="page-panel" id="tab-partners">

    <!-- STAKEHOLDER: VGR -->
    <div class="stakeholder">
      <div class="stakeholder__inner">
        <div class="stakeholder__logo">
          <img src="/logos/vgr.svg" alt="Västra Götalandsregionen" />
        </div>
        <div class="stakeholder__content">
          <p class="stakeholder__tag">Regional funder</p>
          <h2 class="stakeholder__title">Västra Götalandsregionen</h2>
          <p class="stakeholder__body">Västra Götalandsregionen is one of Sweden's largest regions, responsible for healthcare, public transport and regional development. Within culture and the creative industries, the region actively works to strengthen the conditions for art, music and cultural life across Västra Götaland.</p>
          <p class="stakeholder__body">As a funder in Tune In West, VGR contributes resources and strategic expertise to build a stronger music industry in the region — with a focus on growth, innovation and sustainability.</p>
          <a href="https://www.vgregion.se" target="_blank" rel="noopener" class="stakeholder__link">
            Visit vgregion.se
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- STAKEHOLDER: TILLVÄXTVERKET -->
    <div class="stakeholder stakeholder--alt">
      <div class="stakeholder__inner">
        <div class="stakeholder__logo">
          <img src="/logos/tillvaxtverket.svg" alt="Tillväxtverket" />
        </div>
        <div class="stakeholder__content">
          <p class="stakeholder__tag">National funder</p>
          <h2 class="stakeholder__title">Tillväxtverket</h2>
          <p class="stakeholder__body">Tillväxtverket is a Swedish government agency with a mandate to strengthen businesses' competitiveness and create conditions for sustainable growth across Sweden. The agency administers EU structural funds and national programmes for regional development.</p>
          <p class="stakeholder__body">Through Tune In West, Tillväxtverket supports the music industry's digitalisation, internationalisation and capacity for innovation — with the goal of strengthening the creative industries' contribution to the Swedish economy.</p>
          <a href="https://www.tillvaxtverket.se" target="_blank" rel="noopener" class="stakeholder__link">
            Visit tillvaxtverket.se
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- STAKEHOLDER: BREWHOUSE -->
    <div class="stakeholder">
      <div class="stakeholder__inner">
        <div class="stakeholder__logo">
          <img src="/logos/brewhouse.svg" alt="Brewhouse Inkubator" />
        </div>
        <div class="stakeholder__content">
          <p class="stakeholder__tag">Project lead &amp; organiser</p>
          <h2 class="stakeholder__title">Brewhouse Inkubator</h2>
          <p class="stakeholder__body">Brewhouse Inkubator is an incubator programme in Gothenburg that supports entrepreneurs and creative businesses in music, culture and technology. Through structured support, business coaching and a strong network, Brewhouse Inkubator helps new companies grow from idea to sustainable operation.</p>
          <p class="stakeholder__body">As project lead for Tune In West, Brewhouse Inkubator is responsible for coordination, communication and the implementation of most of the project's activities — from the Music Tech Hub Summit to mentorship programmes and LEAN training for music industry actors across Västra Götaland.</p>
          <a href="https://brewhouseinkubator.se" target="_blank" rel="noopener" class="stakeholder__link">
            Visit brewhouseinkubator.se
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- STAKEHOLDER: HSM -->
    <div class="stakeholder stakeholder--alt">
      <div class="stakeholder__inner">
        <div class="stakeholder__logo">
          <img src="/logos/hsm.svg" alt="Högskolan för scen och musik" />
        </div>
        <div class="stakeholder__content">
          <p class="stakeholder__tag">Academic partner</p>
          <h2 class="stakeholder__title">Högskolan för scen och musik</h2>
          <p class="stakeholder__body">Högskolan för scen och musik (at the University of Gothenburg) is one of the Nordic region's leading institutions for artistic education and research in music, opera and performing arts. The school combines hands-on artistic training with cutting-edge academic research.</p>
          <p class="stakeholder__body">Within Tune In West, Högskolan för scen och musik leads Work Package 2 — Music and AI — with pilot projects on AI's role in music creation, copyright questions and knowledge dissemination to the industry in collaboration with national industry organisations.</p>
          <a href="https://www.hsm.gu.se" target="_blank" rel="noopener" class="stakeholder__link">
            Visit hsm.gu.se
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>

  </div>

  <Footer lang={lang} />
</Base>

<style>
  .about-hero { background: var(--black); padding: 88px 40px 72px; position: relative; overflow: hidden; }
  .about-hero::before { display: none; }
  .about-hero__inner { max-width: var(--max); margin: 0 auto; position: relative; z-index: 1; }
  .about-hero__kicker { font-size: 10px; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; color: var(--lime); margin-bottom: 20px; display: block; }
  .about-hero__title { font-size: clamp(52px, 9vw, 120px); font-weight: 800; letter-spacing: -0.045em; line-height: 0.92; margin-bottom: 28px; color: var(--white); }
  .about-hero__subtitle { font-size: 20px; color: rgba(255,255,255,0.7); max-width: 560px; line-height: 1.6; }

  .about-image { aspect-ratio: 16/5; width: 100%; position: relative; overflow: hidden; }
  .about-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .about-image__overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(13,13,13,0.5) 0%, transparent 40%); pointer-events: none; }

  .about-section__kicker { font-size: 10px; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; color: var(--lime); margin-bottom: 16px; display: block; }
  .about-section__title { font-size: clamp(28px, 4vw, 52px); font-weight: 800; letter-spacing: -0.04em; line-height: 1.0; margin-bottom: 24px; color: var(--white); }
  .about-body { font-size: 16px; color: rgba(255,255,255,0.72); line-height: 1.75; margin-bottom: 16px; }

  .about-platform { padding: 80px 40px; border-top: 1px solid var(--black-3); }
  .about-platform__inner { max-width: var(--max); margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
  .about-quote { border-left: 3px solid var(--lime); padding-left: 24px; margin: 0 0 40px; }
  .about-quote p { font-size: 18px; font-style: italic; color: rgba(255,255,255,0.75); line-height: 1.6; }
  .about-stats-mini { display: flex; flex-direction: column; gap: 24px; padding: 32px; border: 1px solid var(--black-3); background: var(--black-2); }
  .about-stat { display: flex; flex-direction: column; gap: 4px; }
  .about-stat__num { font-size: 40px; font-weight: 800; letter-spacing: -0.04em; color: var(--lime); line-height: 1; }
  .about-stat__label { font-size: 13px; color: rgba(255,255,255,0.5); font-weight: 600; }

  .about-project { padding: 80px 40px; background: var(--black-2); border-top: 1px solid var(--black-3); }
  .about-project__inner { max-width: var(--max); margin: 0 auto; }
  .about-project__header { margin-bottom: 48px; }
  .about-ap-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .about-ap-card { display: flex; flex-direction: column; border: 1px solid var(--black-3); padding: 28px 24px; text-decoration: none; color: var(--white); background: var(--black); transition: border-color 0.2s, background 0.2s; }
  .about-ap-card:hover { border-color: var(--lime); background: rgba(208,255,0,0.04); }
  .about-ap-card__num { font-size: 10px; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; color: var(--lime); margin-bottom: 10px; }
  .about-ap-card__title { font-size: 20px; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 12px; color: var(--white); }
  .about-ap-card__desc { font-size: 14px; color: rgba(255,255,255,0.6); line-height: 1.65; flex: 1; margin-bottom: 20px; }
  .about-ap-card__link { font-size: 13px; font-weight: 700; color: var(--lime); }

  .about-themes { padding: 80px 40px; border-top: 1px solid var(--black-3); }
  .about-themes__inner { max-width: var(--max); margin: 0 auto; }
  .about-themes__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; margin-top: 40px; border: 1px solid var(--black-3); }
  .about-theme { padding: 40px 32px; border-right: 1px solid var(--black-3); background: var(--black-2); }
  .about-theme:last-child { border-right: none; }
  .about-theme__icon { width: 48px; height: 48px; border: 1px solid rgba(208,255,0,0.2); display: flex; align-items: center; justify-content: center; margin-bottom: 20px; }
  .about-theme__title { font-size: 18px; font-weight: 800; letter-spacing: -0.02em; color: var(--white); margin-bottom: 12px; }
  .about-theme__desc { font-size: 14px; color: rgba(255,255,255,0.6); line-height: 1.7; }

  /* ── Partners panel ── */
  .stakeholder { padding: 72px 40px; border-bottom: 1px solid var(--black-3); }
  .stakeholder--alt { background: var(--black-2); }
  .stakeholder__inner { max-width: var(--max); margin: 0 auto; display: grid; grid-template-columns: 280px 1fr; gap: 72px; align-items: start; }
  .stakeholder__logo { padding: 32px; border: 1px solid var(--black-3); background: var(--black); display: flex; align-items: center; justify-content: center; min-height: 120px; }
  .stakeholder__logo img { max-width: 160px; max-height: 64px; object-fit: contain; filter: brightness(0) invert(1); opacity: 0.85; }
  .stakeholder__tag { font-size: 10px; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; color: var(--lime); margin-bottom: 12px; display: block; }
  .stakeholder__title { font-size: clamp(24px, 3vw, 40px); font-weight: 800; letter-spacing: -0.035em; color: var(--white); margin-bottom: 20px; line-height: 1.05; }
  .stakeholder__body { font-size: 15px; color: rgba(255,255,255,0.68); line-height: 1.75; margin-bottom: 14px; max-width: 600px; }
  .stakeholder__link { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 700; color: var(--lime); text-decoration: none; margin-top: 8px; transition: gap 0.2s; }
  .stakeholder__link:hover { gap: 12px; }

  @media (max-width: 1024px) {
    .about-platform__inner { grid-template-columns: 1fr; gap: 48px; }
    .about-ap-grid { grid-template-columns: 1fr; }
    .about-themes__grid { grid-template-columns: 1fr; }
    .about-theme { border-right: none; border-bottom: 1px solid var(--black-3); }
    .about-theme:last-child { border-bottom: none; }
    .stakeholder__inner { grid-template-columns: 1fr; gap: 36px; }
  }
  @media (max-width: 640px) {
    .about-hero { padding: 64px 20px 56px; }
    .about-platform { padding: 56px 20px; }
    .about-project { padding: 56px 20px; }
    .about-themes { padding: 56px 20px; }
    .about-image { aspect-ratio: 16/7; }
    .stakeholder { padding: 48px 20px; }
  }
</style>
