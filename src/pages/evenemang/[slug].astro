---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import EventCard from '../../components/EventCard.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const events = await getCollection('events', e => e.id.startsWith('sv/'));
  return events.map(ev => ({
    params: { slug: ev.id.replace('sv/', '') },
    props: { ev },
  }));
}

const { ev } = Astro.props;
const { Content } = await render(ev);
const lang = 'sv';

const related = await getCollection('events', e =>
  e.id.startsWith('sv/') && e.id !== ev.id
);

const badgeClass: Record<string, string> = {
  'Tune In West': 'badge--tiw',
  'Kulturverkstaden': 'badge--kv',
  'HSM': 'badge--hsm',
  'VGR': 'badge--vgr',
};
---
<Base title={`${ev.data.title} – Music Hub West`} lang={lang} ogImage={`/images/${ev.data.image}`}>
  <Nav lang={lang} active="events" />

  <div class="event-header">
    <div class="event-header__inner">
      <a href="/evenemang" class="event-header__back">← Alla event</a>
      <div class="event-header__badge">
        <span class={`badge ${badgeClass[ev.data.category]}`}>{ev.data.category}</span>
      </div>
      <h1 class="event-header__title">{ev.data.title}</h1>
      <div class="event-header__bottom">
        <div class="event-meta-row">
          <div><span class="event-meta__label">Datum</span><span class="event-meta__val">{ev.data.date}</span></div>
          <div><span class="event-meta__label">Tid</span><span class="event-meta__val">{ev.data.time}</span></div>
          <div><span class="event-meta__label">Plats</span><span class="event-meta__val">{ev.data.location}</span></div>
        </div>
      </div>
    </div>
  </div>

  <div class="event-layout">
    <div>
      <div class="event-image">
        <img src={`/images/${ev.data.image}`} alt={ev.data.title} />
      </div>
      <div class="event-content">
        <Content />
      </div>
    </div>

    <div class="event-sidebar" id="anmal">
      <div class="event-cta-box">
        <p class="event-cta-box__title">Anmäl dig till eventet</p>
        <div class="event-meta-list">
          <div class="event-meta-item"><span>Datum</span><strong>{ev.data.date}</strong></div>
          <div class="event-meta-item"><span>Tid</span><strong>{ev.data.time}</strong></div>
          <div class="event-meta-item"><span>Plats</span><strong>{ev.data.location}</strong></div>
          {ev.data.spots_left && <div class="event-meta-item"><span>Platser kvar</span><strong>{ev.data.spots_left} av {ev.data.spots_total}</strong></div>}
          {ev.data.cost && <div class="event-meta-item"><span>Kostnad</span><strong>{ev.data.cost}</strong></div>}
        </div>
        <a href="#" class="btn btn--primary" style="width:100%;text-align:center;display:block;">Anmäl dig nu</a>
        <p class="event-cta-box__note">Bekräftelse skickas via e-post</p>
      </div>
      {ev.data.organizer && (
        <div class="event-organizer">
          <p class="event-organizer__label">Arrangör</p>
          <p class="event-organizer__name">{ev.data.organizer}</p>
          {ev.data.organizer_email && <p class="event-organizer__email">{ev.data.organizer_email}</p>}
        </div>
      )}
    </div>
  </div>

  {related.length > 0 && (
    <div class="related-events">
      <div class="related-events__inner">
        <h2 class="related-events__title">Fler event</h2>
        <div class="card-grid">
          {related.slice(0, 3).map(r => (
            <EventCard
              title={r.data.title}
              date={r.data.date}
              time={r.data.time}
              category={r.data.category}
              image={r.data.image}
              slug={r.id.replace('sv/', '')}
              lang={lang}
            />
          ))}
        </div>
      </div>
    </div>
  )}

  <Footer lang={lang} />
</Base>
