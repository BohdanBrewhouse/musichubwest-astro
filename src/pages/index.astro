---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import EventCard from '../components/EventCard.astro';
import { getCollection } from 'astro:content';

const lang = 'sv';
const events = await getCollection('events', e => e.id.startsWith('sv/'));
const sorted = events.sort((a, b) => a.data.date.localeCompare(b.data.date));
const heroSlides = sorted.slice(0, 4);
const cardEvents = sorted.slice(0, 3);
---
<Base title="Music Hub West – Start" lang={lang} description="En plattform för musikindustrins tillväxt i Västra Sverige.">
  <fragment slot="hreflang">
    <link rel="alternate" hreflang="sv" href={new URL('/', Astro.site)} />
    <link rel="alternate" hreflang="en" href={new URL('/en/', Astro.site)} />
  </fragment>

  <Nav lang={lang} active="start" />

  <section class="hero">
    <div class="hero__slides">
      {heroSlides.map((ev, i) => (
        <div class={`hero__slide ${i === 0 ? 'active' : ''}`}>
          <div class="hero__slide-bg"><img src={`/images/${ev.data.image}`} alt="" /></div>
          <div class="hero__slide-content">
            <span class={`badge badge--${ev.data.category === 'Tune In West' ? 'tiw' : ev.data.category === 'Kulturverkstaden' ? 'kv' : 'hsm'} hero__badge`}>{ev.data.category}</span>
            <h1 class="hero__title" data-text={ev.data.title}>{ev.data.title}</h1>
            <p class="hero__subtitle">{ev.data.date} på {ev.data.location}</p>
            <div class="hero__controls">
              <div class="hero__dots">
                {heroSlides.map((_, j) => <button class={`hero__dot ${j === i ? 'active' : ''}`}></button>)}
              </div>
              <a href={`/evenemang/${ev.id.replace('sv/', '')}`} class="btn btn--primary">Anmäl dig nu</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__inner">
      <div class="section__head">
        <h2 class="section__title">Kommande event</h2>
        <a href="/evenemang" class="section__link">Se alla →</a>
      </div>
      <div class="card-grid">
        {cardEvents.map(ev => (
          <EventCard title={ev.data.title} date={ev.data.date} time={ev.data.time}
            category={ev.data.category} image={ev.data.image}
            slug={ev.id.replace('sv/', '')} lang={lang} />
        ))}
      </div>
    </div>
  </section>

  <div class="project-strip">
    <div class="project-strip__inner">
      <h2 class="project-strip__title">Tune in West 2026–2029</h2>
      <p class="project-strip__text">Med finansiering från Tillväxtverket, Västra Götalandsregionen, Högskolan för Scen och Musik samt Brewhouse Göteborg skapas förutsättningar för musikindustrins tillväxt inom Västra Götaland.</p>
      <div class="partner-logos">
        <span class="partner-logo"><img src="/logos/vgr.svg" alt="Västra Götalandsregionen" /></span>
        <span class="partner-logo"><img src="/logos/tillvaxtverket.svg" alt="Tillväxtverket" /></span>
        <span class="partner-logo"><img src="/logos/brewhouse.svg" alt="Brewhouse Göteborg" /></span>
        <span class="partner-logo"><img src="/logos/hsm.svg" alt="HSM" /></span>
      </div>
      <a href="/tune-in-west" class="btn btn--outline" style="margin-top:32px;display:inline-flex;">Läs mer om Tune In West →</a>
    </div>
  </div>

  <Footer lang={lang} />
</Base>
