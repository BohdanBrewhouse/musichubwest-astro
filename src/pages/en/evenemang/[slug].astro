---
import Base from '../../../layouts/Base.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import EventCard from '../../../components/EventCard.astro';
import ShareBar from '../../../components/ShareBar.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const events = await getCollection('events', e => e.id.startsWith('en/'));
  return events.map(ev => ({
    params: { slug: ev.id.replace('en/', '') },
    props: { ev },
  }));
}

const { ev } = Astro.props;
const { Content } = await render(ev);
const lang = 'en';

const related = await getCollection('events', e =>
  e.id.startsWith('en/') && e.id !== ev.id
);

const svEvents = await getCollection('events', e => e.id.startsWith('sv/'));
const svMatch = svEvents.find(e => e.data.translationKey === ev.data.translationKey);
const altUrl = svMatch ? `/evenemang/${svMatch.id.replace('sv/', '')}` : '/evenemang';

const badgeClass: Record<string, string> = {
  'Tune In West': 'badge--tiw',
  'Kulturverkstaden': 'badge--kv',
  'Högskolan för scen och musik': 'badge--hsm',
  'VGR': 'badge--vgr',
};

function toIcsDate(dateStr: string, timeStr: string) {
  const [start] = timeStr.split('–');
  const [h, m] = start.trim().split(':');
  const d = new Date(`${dateStr} ${h}:${m}`);
  if (isNaN(d.getTime())) return '';
  return d.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
}
function toIcsDateEnd(dateStr: string, timeStr: string) {
  const parts = timeStr.split('–');
  const endTime = parts.length > 1 ? parts[1] : parts[0];
  const [h, m] = endTime.trim().split(':');
  const d = new Date(`${dateStr} ${h}:${m}`);
  if (isNaN(d.getTime())) return toIcsDate(dateStr, timeStr);
  d.setHours(d.getHours() + (parts.length === 1 ? 1 : 0));
  return d.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
}

const dtStart = toIcsDate(ev.data.date, ev.data.time);
const dtEnd = toIcsDateEnd(ev.data.date, ev.data.time);
const eventUrl = new URL(`/en/evenemang/${ev.id.replace('en/','')}`, Astro.site).toString();

const googleUrl = dtStart ? `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${encodeURIComponent(ev.data.title)}&dates=${dtStart}/${dtEnd}&location=${encodeURIComponent(ev.data.location)}&details=${encodeURIComponent(eventUrl)}` : null;

const icsContent = dtStart ? [
  'BEGIN:VCALENDAR',
  'VERSION:2.0',
  'BEGIN:VEVENT',
  `DTSTART:${dtStart}`,
  `DTEND:${dtEnd}`,
  `SUMMARY:${ev.data.title}`,
  `LOCATION:${ev.data.location}`,
  `URL:${eventUrl}`,
  'END:VEVENT',
  'END:VCALENDAR'
].join('\r\n') : null;
---
<Base title={`${ev.data.title} – Music Hub West`} lang={lang} ogImage={ev.data.image}>
  <fragment slot="hreflang">
    <link rel="alternate" hreflang="en" href={new URL(`/en/evenemang/${ev.id.replace('en/','')}`, Astro.site)} />
    {svMatch && <link rel="alternate" hreflang="sv" href={new URL(altUrl, Astro.site)} />}
  </fragment>
  <fragment slot="jsonld">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Event",
      "name": ev.data.title,
      "startDate": ev.data.date,
      "location": { "@type": "Place", "name": ev.data.location },
      "organizer": { "@type": "Organization", "name": ev.data.organizer ?? "Music Hub West" },
      "inLanguage": "en",
      "url": new URL(`/en/evenemang/${ev.id.replace('en/','')}`, Astro.site).toString(),
    })} />
  </fragment>
  <Nav lang={lang} active="events" altUrl={altUrl} />

  <div class="event-header">
    <div class="event-header__inner">
      <a href="/en/evenemang" class="event-header__back">← All events</a>
      <div class="event-header__badge">
        <span class={`badge ${badgeClass[ev.data.category]}`}>{ev.data.category}</span>
      </div>
      <h1 class="event-header__title">{ev.data.title}</h1>
      <div class="event-header__bottom">
        <div class="event-meta-row">
          <div class="event-meta-item">
            <span class="event-meta-item__label">Date</span>
            <span class="event-meta-item__value">{ev.data.date}</span>
          </div>
          <div class="event-meta-item">
            <span class="event-meta-item__label">Time</span>
            <span class="event-meta-item__value">{ev.data.time}</span>
          </div>
          <div class="event-meta-item">
            <span class="event-meta-item__label">Location</span>
            <span class="event-meta-item__value">{ev.data.location}</span>
          </div>
        </div>
        <div class="event-header__actions">
          {ev.data.registration_open && (
            <button class="btn btn--primary" onclick="openRegModal()">Register now</button>
          )}
          {googleUrl && (
            <div class="cal-drop" id="cal-drop-en">
              <button class="cal-drop__trigger" aria-expanded="false" onclick="const d=this.closest('.cal-drop');const open=d.classList.toggle('open');this.setAttribute('aria-expanded',open)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17 2h-1V0h-2v2H8V0H6v2H5C3.9 2 3 2.9 3 4v18c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 20H5V9h14v13z"/></svg>
                Add to calendar
                <svg class="cal-drop__arrow" width="10" height="10" viewBox="0 0 10 10" fill="currentColor"><path d="M1 3l4 4 4-4"/></svg>
              </button>
              <div class="cal-drop__menu">
                <a href={googleUrl} target="_blank" rel="noopener noreferrer" class="cal-drop__item">
                  <span class="cal-drop__item-label">Google Calendar</span>
                </a>
                <a href={`/en/evenemang/${ev.id.replace('en/','')}.ics`} class="cal-drop__item">
                  <span class="cal-drop__item-label">Apple / Outlook</span>
                </a>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>

  <ShareBar lang={lang} title={ev.data.title} />

  <div class="event-layout">
    <div>
      <div class="event-image">
        <img src={ev.data.image} alt={ev.data.title} loading="lazy" decoding="async" />
      </div>
      <div class="event-content">
        <Content />
      </div>
    </div>

    <div class="event-sidebar" id="register">
      <div class="event-cta-box">
        <p class="event-cta-box__title">Register for this event</p>
        <div class="event-cta-box__detail">
          <span class="event-cta-box__detail-label">Date</span>
          <span class="event-cta-box__detail-value">{ev.data.date}</span>
        </div>
        <div class="event-cta-box__detail">
          <span class="event-cta-box__detail-label">Time</span>
          <span class="event-cta-box__detail-value">{ev.data.time}</span>
        </div>
        <div class="event-cta-box__detail">
          <span class="event-cta-box__detail-label">Location</span>
          <span class="event-cta-box__detail-value">{ev.data.location}</span>
        </div>
        {ev.data.spots_left && (
          <div class="event-cta-box__detail">
            <span class="event-cta-box__detail-label">Spots left</span>
            <span class="event-cta-box__detail-value">{ev.data.spots_left} of {ev.data.spots_total}</span>
          </div>
        )}
        {ev.data.cost && (
          <div class="event-cta-box__detail">
            <span class="event-cta-box__detail-label">Cost</span>
            <span class="event-cta-box__detail-value">{ev.data.cost}</span>
          </div>
        )}
        {ev.data.registration_open ? (
          <button class="btn btn--primary" onclick="openRegModal()">Register now</button>
        ) : (
          <span class="btn btn--primary btn--disabled">Registration opens soon</span>
        )}
        <p class="event-cta-box__note">Confirmation sent via email</p>
      </div>
      {ev.data.organizer && (
        <div class="event-organiser">
          <p class="event-organiser__label">Organizer</p>
          <p class="event-organiser__name">{ev.data.organizer}</p>
          {ev.data.organizer_email && (
            <p class="event-organiser__contact">{ev.data.organizer_email}</p>
          )}
        </div>
      )}
    </div>
  </div>

  {ev.data.map_query && (
    <section class="event-location">
      <div class="event-location__inner">
        <div class="event-location__info">
          <p class="event-location__kicker">Location</p>
          <h2 class="event-location__name">{ev.data.location}</h2>
          {ev.data.address && <p class="event-location__address">{ev.data.address}</p>}
          <div class="event-location__actions">
            <a
              href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(ev.data.map_query)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="event-location__cta-maps"
            >
              Open in Google Maps →
            </a>
            <button class="event-location__cta-preview" onclick="openMapModal()">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              Preview map
            </button>
          </div>
        </div>
        <button class="event-location__map-placeholder" onclick="openMapModal()" aria-label="Preview map">
          <span class="event-location__map-pin">
            <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
              <circle cx="12" cy="9" r="2.5" fill="currentColor" stroke="none"/>
            </svg>
          </span>
          <span class="event-location__map-placeholder-label">Click to view map</span>
        </button>
      </div>
    </section>
  )}

  {ev.data.map_query && (
    <div class="map-modal" id="map-modal" role="dialog" aria-modal="true" aria-label="Map" hidden>
      <div class="map-modal__backdrop" onclick="closeMapModal()"></div>
      <div class="map-modal__panel">
        <div class="map-modal__header">
          <h3 class="map-modal__title">How to get there</h3>
          <button class="map-modal__close" onclick="closeMapModal()" aria-label="Close">
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
              <line x1="1" y1="1" x2="12" y2="12"/><line x1="12" y1="1" x2="1" y2="12"/>
            </svg>
          </button>
        </div>
        <div class="map-modal__map-wrap" data-src={`https://maps.google.com/maps?q=${encodeURIComponent(ev.data.map_query)}&output=embed&hl=en`}></div>
        <div class="map-modal__transport">
          <p class="map-modal__transport-label">How do you want to get there?</p>
          <div class="map-modal__transport-grid" data-dest={ev.data.map_query}>
            <button class="map-modal__transport-btn" data-mode="driving">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 17H3v-5l2.5-6h13l2.5 6v5h-2"/><path d="M5 17h14"/>
                <circle cx="7.5" cy="17" r="1.5" fill="currentColor" stroke="none"/>
                <circle cx="16.5" cy="17" r="1.5" fill="currentColor" stroke="none"/>
              </svg>
              <span>Driving</span>
            </button>
            <button class="map-modal__transport-btn" data-mode="transit">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="4" y="3" width="16" height="13" rx="2"/>
                <path d="M4 9h16"/><path d="M9 20l-1-4h8l-1 4"/>
                <circle cx="8.5" cy="15" r="1" fill="currentColor" stroke="none"/>
                <circle cx="15.5" cy="15" r="1" fill="currentColor" stroke="none"/>
              </svg>
              <span>Public transport</span>
            </button>
            <button class="map-modal__transport-btn" data-mode="bicycling">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="5.5" cy="16" r="3"/><circle cx="18.5" cy="16" r="3"/>
                <path d="M5.5 16l4.5-7 3 4 2-3h2.5"/>
                <circle cx="16" cy="6" r="1.2" fill="currentColor" stroke="none"/>
              </svg>
              <span>Biking</span>
            </button>
            <button class="map-modal__transport-btn" data-mode="walking">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="4" r="1.5" fill="currentColor" stroke="none"/>
                <path d="M9 20l1.5-5.5-2.5-2.5 2-5"/><path d="M11 7l3 2 2.5-2"/>
                <path d="M13 11.5l1.5 4-2.5 4.5"/>
              </svg>
              <span>Walking</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  )}

  <script is:inline>
    (function () {
      var modal = document.getElementById('map-modal');
      if (!modal) return;

      function openMapModal() {
        var wrap = modal.querySelector('.map-modal__map-wrap');
        if (wrap && !wrap.querySelector('iframe')) {
          var src = wrap.dataset.src;
          if (src) {
            var iframe = document.createElement('iframe');
            iframe.src = src;
            iframe.className = 'map-modal__map';
            iframe.setAttribute('referrerpolicy', 'no-referrer-when-downgrade');
            iframe.title = 'Map';
            wrap.appendChild(iframe);
          }
        }
        modal.hidden = false;
        requestAnimationFrame(function () { requestAnimationFrame(function () { modal.classList.add('open'); }); });
        document.body.style.overflow = 'hidden';
        document.addEventListener('keydown', handleEsc);
      }

      function closeMapModal() {
        modal.classList.remove('open');
        setTimeout(function () { modal.hidden = true; document.body.style.overflow = ''; }, 350);
        document.removeEventListener('keydown', handleEsc);
      }

      function handleEsc(e) { if (e.key === 'Escape') closeMapModal(); }

      function openMapsDir(mode) {
        var grid = modal.querySelector('.map-modal__transport-grid');
        var dest = grid ? grid.dataset.dest : '';
        var url = 'https://www.google.com/maps/dir/?api=1&destination=' + encodeURIComponent(dest) + '&travelmode=' + mode;
        window.open(url, '_blank', 'noopener');
      }

      window.openMapModal = openMapModal;
      window.closeMapModal = closeMapModal;

      modal.querySelectorAll('.map-modal__transport-btn').forEach(function (btn) {
        btn.addEventListener('click', function () { openMapsDir(btn.dataset.mode); });
      });
    })();
  </script>

  {/* ── Registration modal ───────────────────────────── */}
  <div class="map-modal reg-modal" id="reg-modal" role="dialog" aria-modal="true" aria-labelledby="reg-modal-title" hidden>
    <div class="map-modal__backdrop" onclick="closeRegModal()"></div>
    <div class="map-modal__panel">
      <div class="map-modal__header">
        <h3 class="map-modal__title" id="reg-modal-title">Register</h3>
        <button class="map-modal__close" onclick="closeRegModal()" aria-label="Close">
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
            <line x1="1" y1="1" x2="12" y2="12"/><line x1="12" y1="1" x2="1" y2="12"/>
          </svg>
        </button>
      </div>
      <div class="reg-modal__body">
        <div class="reg-modal__event-info">
          <p class="reg-modal__event-label">Event</p>
          <p class="reg-modal__event-name">{ev.data.title}</p>
          <p class="reg-modal__event-meta">{ev.data.date} &nbsp;·&nbsp; {ev.data.location}</p>
        </div>

        <form id="reg-form" class="reg-form" novalidate>
          <input type="hidden" name="eventTitle" value={ev.data.title} />
          <input type="hidden" name="eventSlug" value={ev.id.replace('en/', '')} />
          <input type="hidden" name="eventDate" value={ev.data.date} />
          <input type="hidden" name="lang" value="en" />

          <div class="reg-form__field">
            <label class="reg-form__label" for="reg-namn">Name <span class="reg-form__required">*</span></label>
            <input class="reg-form__input" type="text" id="reg-namn" name="namn" required autocomplete="name" placeholder="Your full name" />
          </div>
          <div class="reg-form__field">
            <label class="reg-form__label" for="reg-epost">Email <span class="reg-form__required">*</span></label>
            <input class="reg-form__input" type="email" id="reg-epost" name="epost" required autocomplete="email" placeholder="your@email.com" />
          </div>
          <div class="reg-form__field">
            <label class="reg-form__label" for="reg-telefon">Phone <span class="reg-form__optional">(optional)</span></label>
            <input class="reg-form__input" type="tel" id="reg-telefon" name="telefon" autocomplete="tel" placeholder="+46 70 000 00 00" />
          </div>

          <div class="reg-form__error" id="reg-error" hidden>
            Something went wrong. Please try again or contact us directly.
          </div>

          <button type="submit" class="btn btn--primary reg-form__submit" id="reg-submit">
            Send registration
          </button>
          <p class="reg-form__note">* Required fields. Confirmation sent to your email.</p>
        </form>

        <div id="reg-success" class="reg-modal__success" hidden>
          <div class="reg-modal__success-check">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h3 class="reg-modal__success-title">Thank you for registering!</h3>
          <p class="reg-modal__success-text">We have received your registration for <strong>{ev.data.title}</strong>. A confirmation will be sent to your email shortly.</p>
          <button class="btn btn--outline" onclick="closeRegModal()">Close</button>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      var regModal = document.getElementById('reg-modal');
      if (!regModal) return;

      function openRegModal() {
        regModal.hidden = false;
        requestAnimationFrame(function () {
          requestAnimationFrame(function () { regModal.classList.add('open'); });
        });
        document.body.style.overflow = 'hidden';
        document.addEventListener('keydown', handleRegEsc);
      }

      function closeRegModal() {
        regModal.classList.remove('open');
        setTimeout(function () { regModal.hidden = true; document.body.style.overflow = ''; }, 350);
        document.removeEventListener('keydown', handleRegEsc);
      }

      function handleRegEsc(e) { if (e.key === 'Escape') closeRegModal(); }

      var form      = document.getElementById('reg-form');
      var submitBtn = document.getElementById('reg-submit');
      var errorEl   = document.getElementById('reg-error');
      var successEl = document.getElementById('reg-success');

      if (form) {
        form.addEventListener('submit', function (e) {
          e.preventDefault();
          submitBtn.textContent = 'Sending...';
          submitBtn.disabled = true;
          errorEl.hidden = true;

          var data = {};
          new FormData(form).forEach(function (val, key) { data[key] = val; });

          fetch('/api/register', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          })
            .then(function (res) {
              if (!res.ok) throw new Error('error');
              return res.json();
            })
            .then(function () {
              form.hidden = true;
              successEl.hidden = false;
            })
            .catch(function () {
              errorEl.hidden = false;
              submitBtn.textContent = 'Send registration';
              submitBtn.disabled = false;
            });
        });
      }

      window.openRegModal  = openRegModal;
      window.closeRegModal = closeRegModal;
    })();
  </script>

  {related.length > 0 && (
    <div class="related-events">
      <div class="related-events__inner">
        <h2 class="related-events__title">More events</h2>
        <div class="card-grid">
          {related.slice(0, 3).map(r => (
            <EventCard
              title={r.data.title}
              date={r.data.date}
              time={r.data.time}
              category={r.data.category}
              image={r.data.image}
              slug={r.id.replace('en/', '')}
              lang={lang}
            />
          ))}
        </div>
      </div>
    </div>
  )}

  <Footer lang={lang} />
</Base>
