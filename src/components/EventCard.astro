---
export interface Props {
  title: string;
  date: string;
  time: string;
  category: string;
  image: string;
  slug: string;
  lang: 'sv' | 'en';
}
const { title, date, time, category, image, slug, lang } = Astro.props;
const base = lang === 'en' ? '/en' : '';

const badgeClass: Record<string, string> = {
  'Tune In West':     'badge--tiw',
  'Kulturverkstaden': 'badge--kv',
  'Högskolan för scen och musik': 'badge--hsm',
  'VGR':              'badge--vgr',
};
---
<a href={`${base}/evenemang/${slug}`} class="event-card" data-category={category}>
  <div class="event-card__image">
    <img src={image} alt={title} loading="lazy" />
    <span class={`badge ${badgeClass[category] ?? ''} event-card__badge`}>{category}</span>
  </div>
  <div class="event-card__body">
    <p class="event-card__datetime">{date} &nbsp;·&nbsp; {time}</p>
    <h3 class="event-card__title">{title}</h3>
  </div>
</a>
