/* ── Dashboard ── */
.stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 32px; }
.stat-card { background: var(--black-2); border: 1px solid var(--black-3); border-radius: 12px; padding: 20px 16px; text-align: center; }
