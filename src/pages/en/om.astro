---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const lang = 'en';
---
<Base title="About – Music Hub West" lang={lang} description="Learn about Music Hub West — a platform for the music industry's growth in Western Sweden.">
 <fragment slot="hreflang">
 <link rel="alternate" hreflang="sv" href={new URL('/om', Astro.site)} />
 <link rel="alternate" hreflang="en" href={new URL('/en/om', Astro.site)} />
 </fragment>

 <Nav lang={lang} active="about" />

 <!-- TAB NAVIGATION -->
 <div class="page-tabs">
 <div class="page-tabs__inner">
 <button class="page-tab active" data-tab="om-oss">About us</button>
 <button class="page-tab" data-tab="kontakt">Contact</button>
 <button class="page-tab" data-tab="partners">Partners</button>
 </div>
 </div>

 <!-- PANEL: ABOUT -->
 <div class="page-panel active" id="tab-om-oss">
 <div class="page-hero">
 <div class="page-hero__inner">
 <h1 class="page-hero__title">Music Hub<br>West</h1>
 <p class="page-hero__subtitle">Here's something about us — what we do and why we exist. A platform that unites the music industry's players in Western Sweden.</p>
 </div>
 </div>
 <div class="brand-photo" style="aspect-ratio:16/5; width:100%; position:relative;">
 <img src="/images/about-hero.png" alt="Gothenburg" style="width:100%;height:100%;object-fit:cover;" />
 <div style="position:absolute;inset:0;background:linear-gradient(to top, rgba(13,13,13,0.5) 0%, transparent 40%); pointer-events:none;"></div>
 </div>
 </div>

 <!-- PANEL: CONTACT -->
 <div class="page-panel" id="tab-kontakt">
 <div class="contact-layout">
 <div>
 <h2 class="contact-title">Contact us</h2>
 <p class="contact-subtitle">With funding from Tillväxtverket, Västra Götalandsregionen, the Academy of Music and Drama, and Brewhouse Gothenburg, we create conditions for the music industry's growth.</p>
 <div class="team-grid">
 <div class="team-card">
 <div class="team-card__photo"></div>
 <p class="team-card__name">Angelica</p>
 <p class="team-card__org">Brewhouse</p>
 <p class="team-card__email">angelica@brewhouse.se</p>
 </div>
 <div class="team-card">
 <div class="team-card__photo"></div>
 <p class="team-card__name">Johan</p>
 <p class="team-card__org">Brewhouse</p>
 <p class="team-card__email">johan@brewhouse.se</p>
 </div>
 <div class="team-card">
 <div class="team-card__photo"></div>
 <p class="team-card__name">Charlotte</p>
 <p class="team-card__org">Brewhouse</p>
 <p class="team-card__email">charlotte@brewhouse.se</p>
 </div>
 <div class="team-card">
 <div class="team-card__photo"></div>
 <p class="team-card__name">Erik</p>
 <p class="team-card__org">Högskolan för scen och musik</p>
 <p class="team-card__email">erik@hsm.se</p>
 </div>
 <div class="team-card">
 <div class="team-card__photo"></div>
 <p class="team-card__name">Jonathan</p>
 <p class="team-card__org">VGR</p>
 <p class="team-card__email">jonathan@vgr.se</p>
 </div>
 <div class="team-card">
 <div class="team-card__photo"></div>
 <p class="team-card__name">Maja-Karin</p>
 <p class="team-card__org">VGR</p>
 <p class="team-card__email">maja-karin@vgr.se</p>
 </div>
 </div>
 </div>
 <div>
 <div class="form-block__title">Send a message</div>
 <form>
 <div class="form__group">
 <label class="form__label" for="name">Name</label>
 <input class="form__input" type="text" id="name" placeholder="Your name" />
 </div>
 <div class="form__group">
 <label class="form__label" for="email">Email</label>
 <input class="form__input" type="email" id="email" placeholder="your@email.com" />
 </div>
 <div class="form__group">
 <label class="form__label" for="org">Organisation</label>
 <input class="form__input" type="text" id="org" placeholder="Company / Organisation" />
 </div>
 <div class="form__group">
 <label class="form__label" for="msg">Message</label>
 <textarea class="form__textarea" id="msg" placeholder="How can we help you?"></textarea>
 </div>
 <button type="submit" class="btn btn--primary" style="width:100%">Send</button>
 </form>
 </div>
 </div>
 </div>

 <!-- PANEL: PARTNERS -->
 <div class="page-panel" id="tab-partners">
 <div style="padding: 48px 40px; max-width: var(--max); margin: 0 auto;">
 <div class="partner-logos">
 <span class="partner-logo"><img src="/logos/vgr.svg" alt="Västra Götalandsregionen" /></span>
 <span class="partner-logo"><img src="/logos/tillvaxtverket.svg" alt="Tillväxtverket" /></span>
 <span class="partner-logo"><img src="/logos/brewhouse.svg" alt="Brewhouse Göteborg" /></span>
 <span class="partner-logo"><img src="/logos/hsm.svg" alt="Högskolan för scen och musik" /></span>
 </div>
 </div>
 <hr class="divider" />
 <div style="padding: 64px 40px; max-width: var(--max); margin: 0 auto;">
 <h2 style="font-size:clamp(26px,3vw,40px); font-weight:800; letter-spacing:-0.03em; margin-bottom:10px;">
 Tune in West 2026–2029
 </h2>
 <p style="font-size:15px; color:rgba(255,255,255,0.7); max-width:520px; line-height:1.6; margin-bottom:8px;">
 With funding from Tillväxtverket, Västra Götalandsregionen, the Academy of Music and Drama and Brewhouse Gothenburg, we create conditions for the music industry's growth in Västra Götaland.
 </p>
 <a href="/en/tune-in-west" style="font-size:14px; font-weight:700; text-decoration:underline; text-underline-offset:3px;">Read more about the project</a>
 <div class="stats-row">
 <div>
 <p class="stat__number" data-count="45">45</p>
 <p class="stat__label">participating companies</p>
 </div>
 <div>
 <p class="stat__number">3 MSEK</p>
 <p class="stat__label">in funding</p>
 </div>
 <div>
 <p class="stat__number" data-count="12">12+</p>
 <p class="stat__label">events per year</p>
 </div>
 </div>
 </div>
 </div>

 <Footer lang={lang} />
</Base>
