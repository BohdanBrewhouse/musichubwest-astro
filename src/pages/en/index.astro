---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import EventCard from '../../components/EventCard.astro';
import { getCollection } from 'astro:content';

const lang = 'en';
const events = await getCollection('events', e => e.id.startsWith('en/'));
const sorted = events.sort((a, b) => a.data.date.localeCompare(b.data.date));
---
<Base title="Music Hub West – Start" lang={lang}>
  <Nav lang={lang} active="start" />
  <section class="hero">
    <div class="hero__slides">
      {sorted.slice(0,4).map((ev, i) => (
        <div class={`hero__slide ${i===0?'active':''}`}>
          <div class="hero__slide-bg"><img src={`/images/${ev.data.image}`} alt="" /></div>
          <div class="hero__slide-content">
            <h1 class="hero__title" data-text={ev.data.title}>{ev.data.title}</h1>
            <p class="hero__subtitle">{ev.data.date} at {ev.data.location}</p>
            <div class="hero__controls">
              <div class="hero__dots">
                {sorted.slice(0,4).map((_,j) => <button class={`hero__dot ${j===i?'active':''}`}></button>)}
              </div>
              <a href={`/en/evenemang/${ev.id.replace('en/','')}`} class="btn btn--primary">Register now</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
  <section class="section"><div class="section__inner">
    <div class="section__head">
      <h2 class="section__title">Upcoming events</h2>
      <a href="/en/evenemang" class="section__link">See all →</a>
    </div>
    <div class="card-grid">
      {sorted.slice(0,3).map(ev => (
        <EventCard title={ev.data.title} date={ev.data.date} time={ev.data.time}
          category={ev.data.category} image={ev.data.image}
          slug={ev.id.replace('en/','')} lang={lang} />
      ))}
    </div>
  </div></section>
  <Footer lang={lang} />
</Base>
