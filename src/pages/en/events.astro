---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import EventCard from '../../components/EventCard.astro';
import { getCollection } from 'astro:content';

const lang = 'en';
const events = await getCollection('events', e => e.id.startsWith('en/'));
const sorted = events.sort((a, b) => a.data.date.localeCompare(b.data.date));

const monthsFull = ['January','February','March','April','May','June','July','August','September','October','November','December'];

const groups: Record<string, typeof sorted> = {};
for (const ev of sorted) {
  const [year, month] = ev.data.date.split('-');
  const key = `${year}-${month}`;
  if (!groups[key]) groups[key] = [];
  groups[key].push(ev);
}

const badgeClass: Record<string, string> = {
  'Tune In West': 'badge--tiw',
  'Kulturverkstaden': 'badge--kv',
  'Högskolan för scen och musik': 'badge--hsm',
  'VGR': 'badge--vgr',
};
---
<Base title="Events – Music Hub West" lang={lang} description="Upcoming events in music, technology and creative business in Western Sweden. Seminars, showcases and industry meetups by Music Hub West.">
  <fragment slot="hreflang">
    <link rel="alternate" hreflang="sv" href={new URL('/evenemang', Astro.site)} />
    <link rel="alternate" hreflang="en" href={new URL('/en/events', Astro.site)} />
  </fragment>
  <fragment slot="jsonld">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Start", "item": Astro.site },
        { "@type": "ListItem", "position": 2, "name": "Events", "item": new URL('/en/events', Astro.site).toString() }
      ]
    })} />
  </fragment>

  <Nav lang={lang} active="events" />

  <!-- Page header -->
  <div class="ev-header">
    <div class="ev-header__inner">
      <div class="ev-header__row">
        <div class="ev-header__left">
          <p class="ev-header__kicker">Music Hub West</p>
          <h1 class="ev-header__title">Events</h1>
        </div>
        <div class="ev-header__right">
          <span class="ev-header__num">{sorted.length}</span>
          <span class="ev-header__num-label">upcoming<br>events</span>
        </div>
      </div>

      <div class="ev-header__bottom">
        <div class="filter-bar ev-filter-bar">
          <span class="filter-bar__label">Filter</span>
          <button class="filter-chip active" data-filter="all" aria-pressed="true">All</button>
          <button class="filter-chip" data-filter="Tune In West" aria-pressed="false">Tune In West</button>
          <button class="filter-chip" data-filter="Kulturverkstaden" aria-pressed="false">Kulturverkstaden</button>
          <button class="filter-chip" data-filter="Högskolan för scen och musik" aria-pressed="false">HSM</button>
          <button class="filter-chip" data-filter="VGR" aria-pressed="false">VGR</button>
        </div>

        <!-- View toggle + nudge -->
        <div class="view-toggle-wrap">
          <div class="agenda-nudge" id="agenda-nudge">
            <span class="agenda-nudge__text">Try list view</span>
            <svg class="agenda-nudge__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <button class="agenda-nudge__close" id="agenda-nudge-close" aria-label="Close">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 2l8 8M10 2l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
          </div>
          <div class="view-toggle" role="group" aria-label="Choose view">
          <button class="view-toggle__btn active" id="btn-grid" aria-pressed="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <rect x="1" y="1" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/>
              <rect x="10" y="1" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/>
              <rect x="1" y="10" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/>
              <rect x="10" y="10" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            <span class="view-toggle__tooltip">Grid view</span>
          </button>
          <button class="view-toggle__btn" id="btn-list" aria-pressed="false">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <line x1="1" y1="4" x2="17" y2="4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="1" y1="9" x2="17" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="1" y1="14" x2="17" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span class="view-toggle__tooltip">Agenda view</span>
          </button>
        </div>
        </div><!-- /view-toggle-wrap -->
      </div>
    </div>
  </div>

  <!-- GRID VIEW -->
  <section class="section ev-view" id="view-grid">
    <div class="section__inner">
      <div class="card-grid">
        {sorted.map(ev => (
          <EventCard
            title={ev.data.title}
            date={ev.data.date}
            time={ev.data.time}
            category={ev.data.category}
            image={ev.data.image}
            slug={ev.id.replace('en/', '')}
            lang={lang}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- LIST VIEW -->
  <div class="agenda ev-view" id="view-list" style="display:none">
    <div class="agenda__inner">
      {Object.entries(groups).map(([key, evs]) => {
        const [year, monthIdx] = key.split('-');
        const mIdx = parseInt(monthIdx, 10) - 1;
        return (
          <div class="agenda-month" data-month-key={key}>
            <div class="agenda-month__label">
              <span class="agenda-month__name">{monthsFull[mIdx]}</span>
              <span class="agenda-month__year">{year}</span>
            </div>
            {evs.map((ev) => {
              const slug = ev.id.replace('en/', '');
              return (
                <a class="agenda-item" href={`/en/events/${slug}`} data-category={ev.data.category}>
                  <div class="agenda-item__body">
                    <div class="agenda-item__top">
                      <span class={`badge ${badgeClass[ev.data.category] ?? ''}`}>{ev.data.category}</span>
                      <h2 class="agenda-item__title">{ev.data.title}</h2>
                    </div>
                    <p class="agenda-item__meta">
                      <span>{ev.data.date}</span>
                      {ev.data.location && <><span class="agenda-item__dot">·</span><span>{ev.data.location}</span></>}
                      {ev.data.time && <><span class="agenda-item__dot">·</span><span>{ev.data.time}</span></>}
                    </p>
                  </div>
                  <span class="agenda-item__link">
                    {ev.data.registration_open ? 'Register' : 'Read more'}
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                </a>
              );
            })}
          </div>
        );
      })}
      <div id="agenda-empty" hidden>
        <p class="agenda-empty-msg">No events match the selected filter.</p>
      </div>
    </div>
  </div>

  <Footer lang={lang} />
</Base>

<script is:inline>
(function () {
  var STORAGE_KEY = 'mhw-events-view';

  var btnGrid = document.getElementById('btn-grid');
  var btnList = document.getElementById('btn-list');
  var viewGrid = document.getElementById('view-grid');
  var viewList = document.getElementById('view-list');

  function setView(v) {
    var isGrid = v !== 'list';
    viewGrid.style.display = isGrid ? '' : 'none';
    viewList.style.display = isGrid ? 'none' : '';
    btnGrid.classList.toggle('active', isGrid);
    btnList.classList.toggle('active', !isGrid);
    btnGrid.setAttribute('aria-pressed', isGrid ? 'true' : 'false');
    btnList.setAttribute('aria-pressed', isGrid ? 'false' : 'true');
    try { localStorage.setItem(STORAGE_KEY, v); } catch(e) {}
  }

  var NUDGE_KEY = 'mhw-nudge-dismissed';
  var nudge = document.getElementById('agenda-nudge');
  var nudgeClose = document.getElementById('agenda-nudge-close');

  function dismissNudge() {
    if (!nudge) return;
    nudge.style.display = 'none';
    try { localStorage.setItem(NUDGE_KEY, '1'); } catch(e) {}
  }

  try {
    var saved = localStorage.getItem(STORAGE_KEY);
    if (saved === 'list') {
      setView('list');
      if (nudge) nudge.style.display = 'none';
    } else if (localStorage.getItem(NUDGE_KEY) === '1') {
      if (nudge) nudge.style.display = 'none';
    }
  } catch(e) {}

  if (nudge) {
    nudge.addEventListener('click', function(e) {
      if (e.target === nudgeClose || nudgeClose.contains(e.target)) return;
      setView('list');
      dismissNudge();
    });
  }
  if (nudgeClose) {
    nudgeClose.addEventListener('click', function(e) {
      e.stopPropagation();
      dismissNudge();
    });
  }

  btnGrid.addEventListener('click', function() { setView('grid'); });
  btnList.addEventListener('click', function() { setView('list'); dismissNudge(); });

  document.querySelectorAll('.filter-chip').forEach(function(chip) {
    chip.addEventListener('click', function() {
      requestAnimationFrame(function() {
        var anyVisible = false;
        document.querySelectorAll('.agenda-month').forEach(function(group) {
          var items = group.querySelectorAll('.agenda-item');
          var hasVisible = Array.from(items).some(function(el) { return el.style.display !== 'none'; });
          group.style.display = hasVisible ? '' : 'none';
          if (hasVisible) anyVisible = true;
        });
        var empty = document.getElementById('agenda-empty');
        if (empty) empty.hidden = anyVisible;
      });
    });
  });
})();
</script>

<style>
  .ev-header {
    background: var(--black);
    padding: 64px 40px 0;
  }
  .ev-header__inner { max-width: var(--max); margin: 0 auto; }
  .ev-header__row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }
  .ev-header__kicker {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lime);
    margin-bottom: 12px;
  }
  .ev-header__title {
    font-size: clamp(52px, 9vw, 120px);
    font-weight: 800;
    letter-spacing: -0.045em;
    line-height: 0.88;
    color: var(--white);
    margin: 0;
  }
  .ev-header__right {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding-bottom: 10px;
    flex-shrink: 0;
  }
  .ev-header__num {
    font-size: clamp(52px, 6vw, 80px);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--lime);
  }
  .ev-header__num-label {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.35);
    line-height: 1.3;
  }
  .ev-header__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border-top: 1px solid var(--black-3);
    border-bottom: 1px solid var(--black-3);
    padding: 16px 0;
  }
  .ev-filter-bar {
    border-top: none !important;
    padding-top: 0 !important;
    margin-bottom: 0 !important;
    flex: 1;
    min-width: 0;
  }

  /* ── Nudge ── */
  .view-toggle-wrap { position: relative; display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
  .agenda-nudge {
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--lime);
    color: var(--black);
    border-radius: 4px;
    padding: 6px 8px 6px 12px;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.02em;
    white-space: nowrap;
    cursor: pointer;
    transition: opacity 0.2s;
    animation: nudge-in 0.3s ease both;
  }
  @keyframes nudge-in {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .agenda-nudge__arrow { flex-shrink: 0; }
  .agenda-nudge__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    background: rgba(0,0,0,0.15);
    border: none;
    border-radius: 3px;
    cursor: pointer;
    color: var(--black);
    margin-left: 2px;
    flex-shrink: 0;
  }
  .agenda-nudge__close:hover { background: rgba(0,0,0,0.25); }

  .view-toggle { display: flex; gap: 4px; flex-shrink: 0; }
  .view-toggle__btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--black-3);
    border-radius: 4px;
    color: rgba(255,255,255,0.3);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
    position: relative;
  }
  .view-toggle__btn:hover { color: var(--white); border-color: rgba(255,255,255,0.2); }
  .view-toggle__btn.active { color: var(--lime); border-color: var(--lime); background: rgba(204,255,0,0.06); }

  .view-toggle__tooltip {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--black-3);
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--white);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    white-space: nowrap;
    padding: 5px 10px;
    border-radius: 4px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s;
  }
  .view-toggle__tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 4px solid transparent;
    border-top-color: var(--black-3);
  }
  .view-toggle__btn:hover .view-toggle__tooltip { opacity: 1; }

  .agenda { padding: 0 40px 80px; }
  .agenda__inner { max-width: var(--max); margin: 0 auto; }
  .agenda-month { margin-top: 48px; }
  .agenda-month__label {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--black-3);
  }
  .agenda-month__name {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lime);
  }
  .agenda-month__year {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.25);
  }
  .agenda-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 20px 0;
    border-bottom: 1px solid var(--black-3);
    text-decoration: none;
    color: var(--white);
    position: relative;
  }
  .agenda-item::before {
    content: '';
    position: absolute;
    inset: 0 -16px;
    background: var(--black-2);
    opacity: 0;
    transition: opacity 0.15s;
    border-radius: 4px;
    z-index: 0;
  }
  .agenda-item:hover::before { opacity: 1; }
  .agenda-item > * { position: relative; z-index: 1; }
  .agenda-item__body { min-width: 0; flex: 1; }
  .agenda-item__top {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 6px;
    flex-wrap: wrap;
  }
  .agenda-item__title {
    font-size: clamp(15px, 1.6vw, 20px);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--white);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .agenda-item__meta {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .agenda-item__dot { opacity: 0.3; }
  .agenda-item__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 700;
    color: var(--lime);
    white-space: nowrap;
    flex-shrink: 0;
    transition: gap 0.2s;
  }
  .agenda-item:hover .agenda-item__link { gap: 10px; }
  .agenda-empty-msg {
    padding: 64px 0;
    text-align: center;
    color: rgba(255,255,255,0.35);
    font-size: 15px;
  }

  @media (max-width: 768px) {
    .ev-header { padding: 48px 20px 0; }
    .ev-header__bottom { flex-wrap: nowrap; gap: 8px; }
    .ev-filter-bar { overflow-x: auto; -webkit-overflow-scrolling: touch; flex-shrink: 1; }
    .ev-filter-bar::-webkit-scrollbar { display: none; }
    .agenda { padding: 0 20px 56px; }
    .agenda-item__title { white-space: normal; }
  }
  @media (max-width: 640px) {
    .ev-header__right { display: none; }
  }
  @media (max-width: 520px) {
    .agenda-nudge { display: none; }
  }
</style>
