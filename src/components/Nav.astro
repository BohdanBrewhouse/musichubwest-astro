---
export interface Props {
  lang: 'sv' | 'en';
  active?: string;
  altUrl?: string;
}
const { lang, active, altUrl } = Astro.props;

const t = {
  sv: { start: 'Start', events: 'Event', articles: 'Artiklar', about: 'Om' },
  en: { start: 'Start', events: 'Events', articles: 'Articles', about: 'About' },
}[lang];

const base = lang === 'en' ? '/en' : '';
const links = [
  { href: `${base}/`,                               label: t.start,    key: 'start' },
  { href: lang === 'en' ? '/en/events'   : '/evenemang', label: t.events,   key: 'events' },
  { href: lang === 'en' ? '/en/articles' : '/artiklar',  label: t.articles, key: 'articles' },
  { href: lang === 'en' ? '/en/about'    : '/om',        label: t.about,    key: 'about' },
];

const altLang = lang === 'sv' ? 'en' : 'sv';
const altBase = lang === 'sv' ? '/en' : '';
const currentPath = Astro.url.pathname;

// Map EN slugs → SV paths (for language switcher on EN pages without altUrl)
const enToSvMap: Record<string, string> = {
  '/en/about':    '/om',
  '/en/events':   '/evenemang',
  '/en/articles': '/artiklar',
};
// Map SV slugs → EN paths (for language switcher on SV pages without altUrl)
const svToEnMap: Record<string, string> = {
  '/om':       '/en/about',
  '/evenemang':'/en/events',
  '/artiklar': '/en/articles',
};

function getSvUrl(path: string): string {
  // Exact match
  if (enToSvMap[path]) return enToSvMap[path];
  if (enToSvMap[path.replace(/\/$/, '')]) return enToSvMap[path.replace(/\/$/, '')];
  // Dynamic: /en/events/slug → /evenemang/slug
  const m = path.match(/^\/en\/(events|articles)\/(.+)$/);
  if (m) return `/${m[1] === 'events' ? 'evenemang' : 'artiklar'}/${m[2]}`;
  // Fallback: strip /en prefix
  return path.replace(/^\/en/, '') || '/';
}

function getEnUrl(path: string): string {
  if (svToEnMap[path]) return svToEnMap[path];
  if (svToEnMap[path.replace(/\/$/, '')]) return svToEnMap[path.replace(/\/$/, '')];
  // Dynamic: /evenemang/slug → /en/events/slug
  const m = path.match(/^\/(evenemang|artiklar)\/(.+)$/);
  if (m) return `/en/${m[1] === 'evenemang' ? 'events' : 'articles'}/${m[2]}`;
  // Fallback: prepend /en
  return '/en' + path;
}
