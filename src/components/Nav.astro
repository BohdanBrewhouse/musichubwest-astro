          </a>
          <a href="https://www.youtube.com/@musichubwest" target="_blank" rel="noopener" aria-label="YouTube">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="#0d0d0d"/></svg>
          </a>
        </div>
      </li>
    </ul>
    <div class="nav__lang">
      <a href={lang === 'sv' ? (altUrl ?? getEnUrl(currentPath)) : currentPath} data-lang="en" class={`lang-btn ${lang === 'en' ? 'active' : ''}`}>EN</a>
      <a href={lang === 'en' ? (altUrl ?? getSvUrl(currentPath)) : currentPath} data-lang="sv" class={`lang-btn ${lang === 'sv' ? 'active' : ''}`}>SV</a>
    </div>
    <button class="nav__burger" id="nav-burger" aria-label="Meny"><span></span><span></span><span></span></button>
  </div>
</nav>

