---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const lang = 'sv';
---
<Base title="Om oss – Music Hub West" lang={lang} description="Music Hub West är en öppen plattform för musikbranschens aktörer i Västra Götaland — en katalysator för samverkan, innovation och tillväxt.">
  <fragment slot="hreflang">
    <link rel="alternate" hreflang="sv" href={new URL('/om', Astro.site)} />
    <link rel="alternate" hreflang="en" href={new URL('/en/om', Astro.site)} />
  </fragment>

  <Nav lang={lang} active="about" />

  <!-- TAB NAVIGATION -->
  <div class="page-tabs">
    <div class="page-tabs__inner">
      <button class="page-tab active" data-tab="om-oss">Om oss</button>
      <button class="page-tab" data-tab="kontakt">Kontakt</button>
      <button class="page-tab" data-tab="partners">Partners</button>
    </div>
  </div>

  <!-- PANEL: OM OSS -->
  <div class="page-panel active" id="tab-om-oss">

    <!-- HERO -->
    <div class="about-hero">
      <div class="about-hero__inner">
        <p class="about-hero__kicker">Om plattformen</p>
        <h1 class="about-hero__title">Music Hub<br>West</h1>
        <p class="about-hero__subtitle">En öppen mötesplats för musikbranschens aktörer i Västra Götaland — en katalysator för samverkan, innovation och långsiktig tillväxt.</p>
      </div>
    </div>

    <!-- IMAGE -->
    <div class="about-image brand-photo">
      <img src="/images/about-hero.png" alt="Göteborg" />
      <div class="about-image__overlay"></div>
    </div>

    <!-- PLATFORM -->
    <div class="about-platform">
      <div class="about-platform__inner">
        <div class="about-platform__text">
          <p class="about-section__kicker">Plattformen</p>
          <h2 class="about-section__title">Vad är Music Hub West?</h2>
          <p class="about-body">Music Hub West är en öppen plattform för hela musikbranschen i Västra Götaland. Här samlas artister, producenter, musiktechbolag, utbildningsaktörer och kulturinstitutioner för att utbyta kunskap, bygga nätverk och initiera samarbeten.</p>
          <p class="about-body">Plattformen drivs inom ramen för projektet Tune In West (2026–2029) och finansieras av Tillväxtverket, Västra Götalandsregionen, Högskolan för scen och musik samt Brewhouse Göteborg.</p>
          <p class="about-body">Music Hub West är inte en sluten organisation — det är en gemensam arena där branschens aktörer kan mötas, oavsett bakgrund, storlek eller sektor.</p>
        </div>
        <div class="about-platform__highlight">
          <blockquote class="about-quote">
            <p>"En katalysator för nya idéer och affärsmodeller genom att samla resurser, nätverk och kompetens i en gemensam struktur."</p>
          </blockquote>
          <div class="about-stats-mini">
            <div class="about-stat">
              <span class="about-stat__num">45</span>
              <span class="about-stat__label">deltagande bolag</span>
            </div>
            <div class="about-stat">
              <span class="about-stat__num">3 mkr</span>
              <span class="about-stat__label">i finansiering</span>
            </div>
            <div class="about-stat">
              <span class="about-stat__num">12+</span>
              <span class="about-stat__label">event per år</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- PROJECT -->
    <div class="about-project">
      <div class="about-project__inner">
        <div class="about-project__header">
          <p class="about-section__kicker">Projekt 2026–2029</p>
          <h2 class="about-section__title">Tune In West</h2>
          <p class="about-body" style="max-width:640px;">Tune In West är ett tidsbegränsat projekt med syfte att stärka musikindustrins infrastruktur och tillväxt i Västra Götaland. Projektet är organiserat i tre arbetspaket som täcker plattformsbyggande, kunskapsutveckling och direkt företagsstöd.</p>
        </div>
        <div class="about-ap-grid">
          <a href="/tune-in-west/music-hub" class="about-ap-card">
            <span class="about-ap-card__num">AP 1</span>
            <h3 class="about-ap-card__title">Music Hub</h3>
            <p class="about-ap-card__desc">Återkommande branschträffar, seminarier och showcase-evenemang. Varje år arrangeras Music Tech Hub Summit — regionens stora mötesplats för teknik och musik.</p>
            <span class="about-ap-card__link">Läs mer →</span>
          </a>
          <a href="/tune-in-west/musik-och-ai" class="about-ap-card">
            <span class="about-ap-card__num">AP 2</span>
            <h3 class="about-ap-card__title">Musik och AI</h3>
            <p class="about-ap-card__desc">Forskning och kunskapsutveckling kring AI:s roll i musikskapande och upphovsrätt. Akademin och branschorganisationer samverkar för att ta fram och sprida ny kunskap öppet.</p>
            <span class="about-ap-card__link">Läs mer →</span>
          </a>
          <a href="/tune-in-west/kunskapsbyggande" class="about-ap-card">
            <span class="about-ap-card__num">AP 3</span>
            <h3 class="about-ap-card__title">Kunskapsbyggande</h3>
            <p class="about-ap-card__desc">Konkret stöd för små och medelstora musikföretag — LEAN-metodik, mentorskap, internationell studieresa, thinktank och en gemensam samverkansmodell.</p>
            <span class="about-ap-card__link">Läs mer →</span>
          </a>
        </div>
      </div>
    </div>

    <!-- THEMES -->
    <div class="about-themes">
      <div class="about-themes__inner">
        <p class="about-section__kicker">Fokusområden</p>
        <div class="about-themes__grid">
          <div class="about-theme">
            <div class="about-theme__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="var(--lime)" stroke-width="2" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="var(--lime)" stroke-width="2"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="var(--lime)" stroke-width="2" stroke-linecap="round"/></svg>
            </div>
            <h3 class="about-theme__title">Samverkan &amp; nätverk</h3>
            <p class="about-theme__desc">Vi bygger starkare regionala kluster och kopplar samman aktörer från hela Västra Götaland — artister, producenter, tech-bolag och kulturinstitutioner.</p>
          </div>
          <div class="about-theme">
            <div class="about-theme__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5z" stroke="var(--lime)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5" stroke="var(--lime)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="about-theme__title">AI &amp; digitalisering</h3>
            <p class="about-theme__desc">Vi utforskar AI:s möjligheter och risker för musikbranschen — från kreativt skapande och nya produktionsformer till upphovsrätt och immateriella rättigheter.</p>
          </div>
          <div class="about-theme">
            <div class="about-theme__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22V12M12 12L6 6M12 12l6-6M2 22h20" stroke="var(--lime)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="about-theme__title">Hållbar tillväxt</h3>
            <p class="about-theme__desc">Vi stärker musikföretagens innovationsförmåga och konkurrenskraft — med fokus på hållbara affärsmodeller, internationalisering och jämställdhet.</p>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- PANEL: KONTAKT -->
  <div class="page-panel" id="tab-kontakt">
    <div class="contact-layout">
      <div>
        <h2 class="contact-title">Kontakta oss</h2>
        <p class="contact-subtitle">Med finansiering från Tillväxtverket, Västra Götalandsregionen, Högskolan för scen och musik samt Brewhouse Göteborg skapas förutsättningar för musikindustrins tillväxt.</p>
        <div class="team-grid">
          <div class="team-card">
            <div class="team-card__photo"></div>
            <p class="team-card__name">Angelica</p>
            <p class="team-card__org">Brewhouse</p>
            <p class="team-card__email">angelica@brewhouse.se</p>
          </div>
          <div class="team-card">
            <div class="team-card__photo"></div>
            <p class="team-card__name">Johan</p>
            <p class="team-card__org">Brewhouse</p>
            <p class="team-card__email">johan@brewhouse.se</p>
          </div>
          <div class="team-card">
            <div class="team-card__photo"></div>
            <p class="team-card__name">Charlotte</p>
            <p class="team-card__org">Brewhouse</p>
            <p class="team-card__email">charlotte@brewhouse.se</p>
          </div>
          <div class="team-card">
            <div class="team-card__photo"></div>
            <p class="team-card__name">Erik</p>
            <p class="team-card__org">Högskolan för scen och musik</p>
            <p class="team-card__email">erik@hsm.se</p>
          </div>
          <div class="team-card">
            <div class="team-card__photo"></div>
            <p class="team-card__name">Jonathan</p>
            <p class="team-card__org">VGR</p>
            <p class="team-card__email">jonathan@vgr.se</p>
          </div>
          <div class="team-card">
            <div class="team-card__photo"></div>
            <p class="team-card__name">Maja-Karin</p>
            <p class="team-card__org">VGR</p>
            <p class="team-card__email">maja-karin@vgr.se</p>
          </div>
        </div>
      </div>
      <div>
        <div class="form-block__title">Skicka ett meddelande</div>
        <form>
          <div class="form__group">
            <label class="form__label" for="name">Namn</label>
            <input class="form__input" type="text" id="name" placeholder="Ditt namn" />
          </div>
          <div class="form__group">
            <label class="form__label" for="email">E-post</label>
            <input class="form__input" type="email" id="email" placeholder="din@email.se" />
          </div>
          <div class="form__group">
            <label class="form__label" for="org">Organisation</label>
            <input class="form__input" type="text" id="org" placeholder="Företag / Organisation" />
          </div>
          <div class="form__group">
            <label class="form__label" for="msg">Meddelande</label>
            <textarea class="form__textarea" id="msg" placeholder="Vad kan vi hjälpa dig med?"></textarea>
          </div>
          <button type="submit" class="btn btn--primary" style="width:100%">Skicka</button>
        </form>
      </div>
    </div>
  </div>

  <!-- PANEL: PARTNERS -->
  <div class="page-panel" id="tab-partners">

    <!-- LOGOS STRIP -->
    <div class="partners-logos-bar">
      <div class="partners-logos-bar__inner">
        <p class="about-section__kicker" style="margin-bottom:32px;">Finansiärer &amp; partners</p>
        <div class="partner-logos">
          <span class="partner-logo"><img src="/logos/vgr.svg" alt="Västra Götalandsregionen" /></span>
          <span class="partner-logo"><img src="/logos/tillvaxtverket.svg" alt="Tillväxtverket" /></span>
          <span class="partner-logo"><img src="/logos/brewhouse.svg" alt="Brewhouse Göteborg" /></span>
          <span class="partner-logo"><img src="/logos/hsm.svg" alt="Högskolan för scen och musik" /></span>
        </div>
      </div>
    </div>

    <!-- STAKEHOLDER: VGR -->
    <div class="stakeholder">
      <div class="stakeholder__inner">
        <div class="stakeholder__logo">
          <img src="/logos/vgr.svg" alt="Västra Götalandsregionen" />
        </div>
        <div class="stakeholder__content">
          <p class="stakeholder__tag">Regional finansiär</p>
          <h2 class="stakeholder__title">Västra Götalandsregionen</h2>
          <p class="stakeholder__body">Västra Götalandsregionen är en av Sveriges största regioner och ansvarar för hälso- och sjukvård, kollektivtrafik samt regional utveckling. Inom kultur och kreativa näringar arbetar regionen aktivt för att stärka förutsättningarna för konst, musik och kulturliv i hela Västra Götaland.</p>
          <p class="stakeholder__body">Som finansiär i Tune In West bidrar VGR med resurser och strategisk kompetens för att bygga en starkare musikbransch i regionen — med fokus på tillväxt, innovation och hållbarhet.</p>
          <a href="https://www.vgregion.se" target="_blank" rel="noopener" class="stakeholder__link">
            Besök vgregion.se
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- STAKEHOLDER: TILLVÄXTVERKET -->
    <div class="stakeholder stakeholder--alt">
      <div class="stakeholder__inner">
        <div class="stakeholder__logo">
          <img src="/logos/tillvaxtverket.svg" alt="Tillväxtverket" />
        </div>
        <div class="stakeholder__content">
          <p class="stakeholder__tag">Nationell finansiär</p>
          <h2 class="stakeholder__title">Tillväxtverket</h2>
          <p class="stakeholder__body">Tillväxtverket är en statlig myndighet med uppdrag att stärka företagens konkurrenskraft och skapa förutsättningar för hållbar tillväxt i alla delar av Sverige. Myndigheten administrerar EU:s strukturfonder och nationella program för regional utveckling.</p>
          <p class="stakeholder__body">Genom Tune In West stödjer Tillväxtverket musikbranschens digitalisering, internationalisering och innovationsförmåga — med målet att stärka de kreativa näringarnas bidrag till den svenska ekonomin.</p>
          <a href="https://www.tillvaxtverket.se" target="_blank" rel="noopener" class="stakeholder__link">
            Besök tillvaxtverket.se
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- STAKEHOLDER: BREWHOUSE -->
    <div class="stakeholder">
      <div class="stakeholder__inner">
        <div class="stakeholder__logo">
          <img src="/logos/brewhouse.svg" alt="Brewhouse Göteborg" />
        </div>
        <div class="stakeholder__content">
          <p class="stakeholder__tag">Projektledare &amp; genomförare</p>
          <h2 class="stakeholder__title">Brewhouse Göteborg</h2>
          <p class="stakeholder__body">Brewhouse är Göteborg och Västsveriges ledande mötesplats för musikbranschen — ett kreativt nav där artister, producenter, bolag och kulturaktörer samlas. Sedan starten har Brewhouse arbetat för att stärka musikekosystemet i regionen genom event, nätverk och affärsutveckling.</p>
          <p class="stakeholder__body">Som projektledare för Tune In West ansvarar Brewhouse för koordinering, kommunikation och genomförande av merparten av projektets aktiviteter — från Music Tech Hub Summit till mentorsprogram och LEAN-utbildningar.</p>
          <a href="https://brewhouse.se" target="_blank" rel="noopener" class="stakeholder__link">
            Besök brewhouse.se
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- STAKEHOLDER: HSM -->
    <div class="stakeholder stakeholder--alt">
      <div class="stakeholder__inner">
        <div class="stakeholder__logo">
          <img src="/logos/hsm.svg" alt="Högskolan för scen och musik" />
        </div>
        <div class="stakeholder__content">
          <p class="stakeholder__tag">Akademisk partner</p>
          <h2 class="stakeholder__title">Högskolan för scen och musik</h2>
          <p class="stakeholder__body">Högskolan för scen och musik (vid Göteborgs universitet) är en av Nordens ledande institutioner för konstnärlig utbildning och forskning inom musik, opera och scenkonst. Skolan kombinerar praktisk konstnärlig utbildning med akademisk forskning i framkant.</p>
          <p class="stakeholder__body">Inom Tune In West ansvarar Högskolan för scen och musik för arbetspaket 2 — Musik och AI — med pilotprojekt kring AI:s roll i musikskapande, upphovsrättsliga frågor och kunskapsspridning till branschen i samverkan med nationella branschorganisationer.</p>
          <a href="https://www.hsm.gu.se" target="_blank" rel="noopener" class="stakeholder__link">
            Besök hsm.gu.se
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>

  </div>

  <Footer lang={lang} />
</Base>

<style>
  /* ── About hero ── */
  .about-hero {
    background: var(--black);
    padding: 88px 40px 72px;
    position: relative;
    overflow: hidden;
  }
  .about-hero::before {
    content: '';
    position: absolute;
    top: -140px; right: -140px;
    width: 700px; height: 700px;
    background: var(--lime);
    opacity: 0.1;
    border-radius: 50%;
    pointer-events: none;
  }
  .about-hero__inner {
    max-width: var(--max);
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .about-hero__kicker {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lime);
    margin-bottom: 20px;
  }
  .about-hero__title {
    font-size: clamp(52px, 9vw, 120px);
    font-weight: 800;
    letter-spacing: -0.045em;
    line-height: 0.92;
    margin-bottom: 28px;
    color: var(--white);
  }
  .about-hero__subtitle {
    font-size: 20px;
    color: rgba(255,255,255,0.7);
    max-width: 560px;
    line-height: 1.6;
  }

  /* ── Image ── */
  .about-image {
    aspect-ratio: 16/5;
    width: 100%;
    position: relative;
    overflow: hidden;
  }
  .about-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .about-image__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(13,13,13,0.5) 0%, transparent 40%);
    pointer-events: none;
  }

  /* ── Shared section styles ── */
  .about-section__kicker {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lime);
    margin-bottom: 16px;
    display: block;
  }
  .about-section__title {
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.0;
    margin-bottom: 24px;
    color: var(--white);
  }
  .about-body {
    font-size: 16px;
    color: rgba(255,255,255,0.72);
    line-height: 1.75;
    margin-bottom: 16px;
  }

  /* ── Platform section ── */
  .about-platform {
    padding: 80px 40px;
    border-top: 1px solid var(--black-3);
  }
  .about-platform__inner {
    max-width: var(--max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .about-quote {
    border-left: 3px solid var(--lime);
    padding-left: 24px;
    margin: 0 0 40px;
  }
  .about-quote p {
    font-size: 18px;
    font-style: italic;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
  }
  .about-stats-mini {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 32px;
    border: 1px solid var(--black-3);
    background: var(--black-2);
  }
  .about-stat { display: flex; flex-direction: column; gap: 4px; }
  .about-stat__num {
    font-size: 40px;
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--lime);
    line-height: 1;
  }
  .about-stat__label { font-size: 13px; color: rgba(255,255,255,0.5); font-weight: 600; }

  /* ── Project section ── */
  .about-project {
    padding: 80px 40px;
    background: var(--black-2);
    border-top: 1px solid var(--black-3);
  }
  .about-project__inner { max-width: var(--max); margin: 0 auto; }
  .about-project__header { margin-bottom: 48px; }
  .about-ap-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .about-ap-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--black-3);
    padding: 28px 24px;
    text-decoration: none;
    color: var(--white);
    background: var(--black);
    transition: border-color 0.2s, background 0.2s;
  }
  .about-ap-card:hover { border-color: var(--lime); background: rgba(208,255,0,0.04); }
  .about-ap-card__num {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--lime);
    margin-bottom: 10px;
  }
  .about-ap-card__title {
    font-size: 20px;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
    color: var(--white);
  }
  .about-ap-card__desc {
    font-size: 14px;
    color: rgba(255,255,255,0.6);
    line-height: 1.65;
    flex: 1;
    margin-bottom: 20px;
  }
  .about-ap-card__link { font-size: 13px; font-weight: 700; color: var(--lime); }

  /* ── Themes section ── */
  .about-themes {
    padding: 80px 40px;
    border-top: 1px solid var(--black-3);
  }
  .about-themes__inner { max-width: var(--max); margin: 0 auto; }
  .about-themes__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 40px;
    border: 1px solid var(--black-3);
  }
  .about-theme {
    padding: 40px 32px;
    border-right: 1px solid var(--black-3);
    background: var(--black-2);
  }
  .about-theme:last-child { border-right: none; }
  .about-theme__icon {
    width: 48px;
    height: 48px;
    border: 1px solid rgba(208,255,0,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
