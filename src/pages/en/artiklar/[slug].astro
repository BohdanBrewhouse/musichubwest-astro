---
import Base from '../../../layouts/Base.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles', a => a.id.startsWith('en/'));
  return articles.map(a => ({
    params: { slug: a.id.replace('en/', '') },
    props: { article: a },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const lang = 'en';

const svArticles = await getCollection('articles', a => a.id.startsWith('sv/'));
const svMatch = svArticles.find(a => a.data.translationKey === article.data.translationKey);
const altUrl = svMatch ? `/artiklar/${svMatch.id.replace('sv/', '')}` : '/artiklar';

const badgeClass: Record<string, string> = {
  'Tune In West': 'badge--tiw',
  'Kulturverkstaden': 'badge--kv',
  'HSM': 'badge--hsm',
  'VGR': 'badge--vgr',
};
---
<Base title={`${article.data.title} – Music Hub West`} lang={lang}>
  <Nav lang={lang} active="articles" altUrl={altUrl} />

  <div class="article-header">
    <a href="/en/artiklar" class="article-header__back">← All articles</a>
    <div class="article-header__badge">
      <span class={`badge ${badgeClass[article.data.category] ?? ''}`}>{article.data.category}</span>
    </div>
    <h1 class="article-header__title">{article.data.title}</h1>
    <div class="article-header__meta">
      <div class="article-header__author">
        <div class="article-header__avatar"></div>
        <div>
          <p class="article-header__author-name">{article.data.author}</p>
        </div>
      </div>
      <span class="article-header__date">{article.data.date}</span>
    </div>
  </div>

  {article.data.image && (
    <div class="article-image">
      <div class="article-image__inner">
        <img src={`/images/${article.data.image}`} alt={article.data.title} />
      </div>
    </div>
  )}

  <div class="article-body">
    <Content />
  </div>

  <Footer lang={lang} />
</Base>
